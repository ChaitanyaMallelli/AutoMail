@{
    ViewData["Title"] = "Live Activity Tracker";
    ViewData["Subtitle"] = "Real-time pipeline monitoring for your Telegram bot";
}

<div class="row justify-content-center">
    <div class="col-xl-8 col-lg-10">

        <!-- Pipeline Card -->
        <div class="detail-card" style="position: relative; overflow: hidden; min-height: 540px; background: rgba(14, 20, 38, 0.80); backdrop-filter: blur(16px); box-shadow: var(--shadow-lg); border-color: rgba(255, 255, 255, 0.07);">

            <!-- Ambient glow orbs (decorative) -->
            <div style="position: absolute; top: -80px; left: -80px; width: 260px; height: 260px; background: rgba(99, 102, 241, 0.12); filter: blur(70px); border-radius: 50%; pointer-events: none;"></div>
            <div style="position: absolute; bottom: -80px; right: -80px; width: 240px; height: 240px; background: rgba(168, 85, 247, 0.10); filter: blur(70px); border-radius: 50%; pointer-events: none;"></div>
            <!-- Dot-grid texture -->
            <div style="position: absolute; inset: 0; opacity: 0.025; background-image: radial-gradient(var(--color-accent) 1px, transparent 1px); background-size: 22px 22px; pointer-events: none;"></div>

            <!-- Card Header -->
            <div class="d-flex align-items-center justify-content-between mb-4 pb-3" style="border-bottom: 1px solid rgba(255, 255, 255, 0.07); position: relative;">
                <div class="d-flex align-items-center gap-2">
                    <div style="width: 34px; height: 34px; min-width: 34px; border-radius: 9px; background: var(--color-accent-bg); border: 1px solid rgba(99, 102, 241, 0.25); display: flex; align-items: center; justify-content: center; font-size: 16px; color: var(--color-accent-light);">
                        <i class="bi bi-cpu-fill animate-pulse"></i>
                    </div>
                    <div>
                        <h5 class="mb-0 fw-bold text-white" style="font-size: 15px; letter-spacing: -0.3px;">Telegram Automation Pipeline</h5>
                        <span class="text-xs" style="color: var(--color-text-muted);">Polling every second &mdash; updates appear instantly</span>
                    </div>
                </div>
                <span class="status-badge status-pending" id="pipelineState" style="font-weight: 600; letter-spacing: 0.4px;">
                    <span class="spinner-grow spinner-grow-sm me-1" role="status" style="width: 8px; height: 8px; color: var(--color-warning);"></span>
                    Listening for Updates
                </span>
            </div>

            <!-- ─────────── EMPTY STATE ─────────── -->
            <div id="emptyTracker" class="empty-state py-5">
                <!-- Animated signal icon -->
                <div class="mb-4" style="position: relative; width: 88px; height: 88px; margin: 0 auto;">
                    <div style="position: absolute; inset: 0; border-radius: 50%; background: var(--color-accent-bg); border: 1px solid rgba(99, 102, 241, 0.20); animation: pulseBounce 2.2s ease-in-out infinite;"></div>
                    <div style="position: absolute; inset: 10px; border-radius: 50%; background: rgba(99, 102, 241, 0.07); animation: pulseBounce 2.2s ease-in-out infinite 0.3s;"></div>
                    <div style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; font-size: 36px; color: var(--color-accent-light); filter: drop-shadow(0 0 12px var(--color-accent-glow));">
                        <i class="bi bi-rss-fill"></i>
                    </div>
                </div>

                <h4 class="text-white fw-bold mb-2">Awaiting Telegram Input</h4>
                <p class="text-sm mx-auto mb-4" style="max-width: 420px; line-height: 1.7; color: var(--color-text-secondary);">
                    Send a text job post, LinkedIn screenshot, or PDF description to your bot.
                    This dashboard will instantly intercept the message and track every pipeline step in real time.
                </p>
                <a href="https://t.me/your_bot" target="_blank" id="botLaunchLink" class="btn btn-glow rounded-pill px-4 text-sm fw-semibold">
                    <i class="bi bi-telegram me-1"></i> Open Telegram Bot Chat
                </a>
            </div>

            <!-- ─────────── ACTIVE TRACKER ─────────── -->
            <div id="activeTracker" style="display: none;">

                <!-- Header info bar: Sender + Job ID side by side -->
                <div class="row g-3 mb-4">
                    <div class="col-sm-6">
                        <div class="p-3 h-100 rounded-3" style="background: rgba(99, 102, 241, 0.06); border: 1px solid rgba(99, 102, 241, 0.14);">
                            <span class="detail-label mb-1">Active Sender ID</span>
                            <span class="d-block fw-bold text-white" style="font-size: 16px;" id="chatIdLabel">—</span>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="p-3 h-100 rounded-3" style="background: rgba(99, 102, 241, 0.06); border: 1px solid rgba(99, 102, 241, 0.14);">
                            <span class="detail-label mb-1">Job Status Card</span>
                            <span class="d-block fw-bold text-white" style="font-size: 16px;" id="jobIdLabel">—</span>
                        </div>
                    </div>
                </div>

                <!-- Pipeline Stepper -->
                <div class="pipeline-stepper">

                    <!-- Step 1 -->
                    <div class="step-card step-inactive" id="stepCard1">
                        <div class="step-dot"><i class="bi bi-circle"></i></div>
                        <div class="step-header">Step 1 &mdash; Input Detection</div>
                        <div class="step-subheader" id="stepSub1">Waiting for file or text message from Telegram...</div>
                    </div>

                    <!-- Step 2 -->
                    <div class="step-card step-inactive" id="stepCard2">
                        <div class="step-dot"><i class="bi bi-circle"></i></div>
                        <div class="step-header">Step 2 &mdash; Gemini AI Extraction</div>
                        <div class="step-subheader" id="stepSub2">Extracting company, role, requirements, and recruiter details...</div>
                    </div>

                    <!-- Step 3 -->
                    <div class="step-card step-inactive" id="stepCard3">
                        <div class="step-dot"><i class="bi bi-circle"></i></div>
                        <div class="step-header">Step 3 &mdash; Skill Matching &amp; ATS Analysis</div>
                        <div class="step-subheader" id="stepSub3">Calculating skill similarity and ATS optimisation score...</div>
                    </div>

                    <!-- Step 4 -->
                    <div class="step-card step-inactive" id="stepCard4">
                        <div class="step-dot"><i class="bi bi-circle"></i></div>
                        <div class="step-header">Step 4 &mdash; AI Email Draft Synthesis</div>
                        <div class="step-subheader" id="stepSub4">Composing personalised outreach draft matching your profile...</div>
                    </div>

                    <!-- Step 5 -->
                    <div class="step-card step-inactive" id="stepCard5">
                        <div class="step-dot"><i class="bi bi-circle"></i></div>
                        <div class="step-header">Step 5 &mdash; Interactive Approval Loop</div>
                        <div class="step-subheader" id="stepSub5">Awaiting decision card confirmation on Telegram...</div>
                    </div>

                </div>

                <!-- Web Approval Alert Banner (shown only for web-triggered applications) -->
                <div id="webApprovalAlert" class="mt-4 p-4 rounded-3 text-center" style="display: none; background: rgba(59, 130, 246, 0.07); border: 1px solid rgba(59, 130, 246, 0.20);">
                    <div class="mb-2" style="font-size: 28px; color: var(--color-info-light);">
                        <i class="bi bi-envelope-check-fill animate-pulse"></i>
                    </div>
                    <h5 class="text-white fw-bold mb-1">Email Draft is Ready!</h5>
                    <p class="text-sm mb-3" style="color: var(--color-text-secondary); max-width: 380px; margin-left: auto; margin-right: auto; line-height: 1.6;">
                        Since you applied through the dashboard, you can review, edit, and send the generated email right here.
                    </p>
                    <a href="#" id="webApprovalLink" class="btn btn-glow rounded-pill px-4 fw-semibold">
                        <i class="bi bi-eye-fill me-1"></i> Review &amp; Send Email
                    </a>
                </div>

            </div>
            <!-- / #activeTracker -->

        </div>
        <!-- / Pipeline Card -->

    </div>
</div>

@section Scripts {
    <script>
        let lastStepsHash = "";

        async function pollStatus() {
            try {
                const response = await fetch('/Telegram/GetLiveStatus');
                if (!response.ok) return;

                const data = await response.json();

                if (!data || data.length === 0) {
                    document.getElementById("emptyTracker").style.display = "block";
                    document.getElementById("activeTracker").style.display = "none";

                    const stateBadge = document.getElementById("pipelineState");
                    stateBadge.className = "status-badge status-pending";
                    stateBadge.innerHTML = `<span class="spinner-grow spinner-grow-sm me-1" role="status" style="width: 8px; height: 8px; color: var(--color-warning);"></span> Listening for Updates`;
                    return;
                }

                // Show active pipeline (use the most recent execution)
                const activeProcess = data[data.length - 1];
                const isWebTrigger = activeProcess.chatId === 999;

                document.getElementById("emptyTracker").style.display = "none";
                document.getElementById("activeTracker").style.display = "block";

                // Hide web approval banner by default; show it only for web jobs with a ready jobId
                if (!isWebTrigger) document.getElementById("webApprovalAlert").style.display = "none";

                document.getElementById("chatIdLabel").innerText = isWebTrigger ? "Web Dashboard" : activeProcess.chatId;

                if (activeProcess.jobId && activeProcess.jobId > 0) {
                    document.getElementById("jobIdLabel").innerHTML = `<a href="/Email/Preview/${activeProcess.jobId}" class="text-accent-light fw-bold text-decoration-none"><i class="bi bi-eye"></i> Job #${activeProcess.jobId}</a>`;

                    // Show the local review banner for web-triggered applications
                    if (isWebTrigger) {
                        const alert = document.getElementById("webApprovalAlert");
                        const link = document.getElementById("webApprovalLink");
                        link.href = `/Email/Preview/${activeProcess.jobId}`;
                        alert.style.display = "block";
                    }
                } else {
                    document.getElementById("jobIdLabel").innerText = "Extracting... ⏳";
                }

                const steps = activeProcess.steps || [];

                // Build unique hash to prevent redundant DOM updates
                const currentHash = JSON.stringify(steps) + "_" + activeProcess.jobId;
                if (currentHash === lastStepsHash) return;
                lastStepsHash = currentHash;

                // Reset all steps to inactive
                for (let i = 1; i <= 5; i++) {
                    const card = document.getElementById(`stepCard${i}`);
                    card.className = "step-card step-inactive";
                    card.querySelector(".step-dot").innerHTML = '<i class="bi bi-circle"></i>';
                }

                let currentRunningStep = 0;
                let isAnyFailed = false;

                steps.forEach((step) => {
                    let stepNum = 0;
                    if (step.startsWith("Step 1")) stepNum = 1;
                    else if (step.startsWith("Step 2")) stepNum = 2;
                    else if (step.startsWith("Step 3")) stepNum = 3;
                    else if (step.startsWith("Step 4")) stepNum = 4;
                    else if (step.startsWith("Step 5")) stepNum = 5;
                    else if (step.startsWith("Step 6")) stepNum = 6; // Sent state

                    if (stepNum === 0) return;

                    let status = "completed"; // Default to success/completed
                    let cleanText = step;
                    let iconHtml = '<i class="bi bi-check-lg"></i>';

                    if (step.endsWith("⏳")) {
                        status = "pending";
                        iconHtml = '<span class="spinner-border spinner-border-sm" style="width: 10px; height: 10px;"></span>';
                        cleanText = step.substring(0, step.length - 2);
                        currentRunningStep = stepNum;
                    } else if (step.endsWith("✅")) {
                        status = "completed";
                        iconHtml = '<i class="bi bi-check-lg"></i>';
                        cleanText = step.substring(0, step.length - 2);
                    } else if (step.endsWith("❌")) {
                        status = "failed";
                        iconHtml = '<i class="bi bi-x-lg"></i>';
                        cleanText = step.substring(0, step.length - 2);
                        isAnyFailed = true;
                    } else if (step.endsWith("⚠️")) {
                        status = "completed"; // Treat warnings as completed with symbol
                        iconHtml = '<i class="bi bi-exclamation-triangle-fill"></i>';
                        cleanText = step.substring(0, step.length - 2);
                    }

                    // Remove leading "Step X:" for subheaders
                    const colonIndex = cleanText.indexOf(':');
                    if (colonIndex >= 0) {
                        cleanText = cleanText.substring(colonIndex + 1).trim();
                    }

                    if (stepNum <= 5) {
                        const card = document.getElementById(`stepCard${stepNum}`);
                        const subHeader = document.getElementById(`stepSub${stepNum}`);

                        subHeader.innerText = cleanText;

                        if (status === "completed") {
                            card.className = "step-card step-completed";
                            card.querySelector(".step-dot").innerHTML = iconHtml;
                        } else if (status === "pending") {
                            card.className = "step-card step-active-now animate-pulse";
                            card.querySelector(".step-dot").innerHTML = iconHtml;
                        } else if (status === "failed") {
                            card.className = "step-card step-failed-now";
                            card.querySelector(".step-dot").innerHTML = iconHtml;
                        }
                    } else if (stepNum === 6) {
                        // This indicates approval complete / mail sent!
                        const card5 = document.getElementById("stepCard5");
                        const sub5 = document.getElementById("stepSub5");
                        if (status === "completed") {
                            card5.className = "step-card step-completed";
                            card5.querySelector(".step-dot").innerHTML = '<i class="bi bi-send-check-fill"></i>';
                            sub5.innerHTML = `<b>Approved!</b> ${cleanText}`;
                        } else if (status === "pending") {
                            card5.className = "step-card step-active-now";
                            card5.querySelector(".step-dot").innerHTML = '<span class="spinner-border spinner-border-sm" style="width: 10px; height: 10px;"></span>';
                            sub5.innerHTML = `<b>Processing Approval...</b> ${cleanText}`;
                        } else if (status === "failed") {
                            card5.className = "step-card step-failed-now";
                            card5.querySelector(".step-dot").innerHTML = '<i class="bi bi-x-circle-fill"></i>';
                            sub5.innerHTML = `<b>Approval failed:</b> ${cleanText}`;
                        }
                    }
                });

                // Update pipeline status badge
                const stateBadge = document.getElementById("pipelineState");
                if (isAnyFailed) {
                    stateBadge.className = "status-badge status-failed px-3 py-1.5";
                    stateBadge.innerHTML = `<i class="bi bi-x-circle-fill"></i> Execution Failed`;
                } else if (currentRunningStep > 0) {
                    stateBadge.className = "status-badge status-ready px-3 py-1.5";
                    stateBadge.innerHTML = `<span class="spinner-border spinner-border-sm me-1" style="width: 10px; height: 10px;"></span> Step ${currentRunningStep} in Progress`;
                } else {
                    stateBadge.className = "status-badge status-sent px-3 py-1.5";
                    stateBadge.innerHTML = `<i class="bi bi-check-circle-fill"></i> Done`;
                }

            } catch (err) {
                console.error("Failed to poll status", err);
            }
        }

        // Fetch bot profile details and setup
        async function loadBotProfile() {
            try {
                const response = await fetch('/Telegram');
                const text = await response.text();
                const parser = new DOMParser();
                const htmlDoc = parser.parseFromString(text, 'text/html');
                const botLink = htmlDoc.querySelector("a[href*='t.me']");
                if (botLink) {
                    const launchBtn = document.getElementById("botLaunchLink");
                    launchBtn.href = botLink.href;
                    launchBtn.innerHTML = `<i class="bi bi-telegram me-1"></i> Open Chat (${botLink.innerText.trim()})`;
                }
            } catch (e) {}
        }

        // Poll immediately and then every 1 second
        pollStatus();
        loadBotProfile();
        setInterval(pollStatus, 1000);
    </script>
}
