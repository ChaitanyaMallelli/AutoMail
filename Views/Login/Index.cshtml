@{
    Layout = null; // Do not use the main layout with headers/footers
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Authentication Required | Job Automation Bot</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: radial-gradient(circle at top right, rgb(20, 24, 45) 0%, rgb(8, 10, 18) 100%);
            min-height: 100vh;
            color: #f3f4f6;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            position: relative;
        }

        /* Neon circles behind the card */
        .glow-circle-1 {
            position: absolute;
            width: 400px;
            height: 400px;
            background: rgba(99, 102, 241, 0.15);
            filter: blur(120px);
            border-radius: 50%;
            top: 15%;
            left: 20%;
            pointer-events: none;
        }
        
        .glow-circle-2 {
            position: absolute;
            width: 300px;
            height: 300px;
            background: rgba(168, 85, 247, 0.12);
            filter: blur(100px);
            border-radius: 50%;
            bottom: 15%;
            right: 20%;
            pointer-events: none;
        }

        .login-card {
            border: 1px solid rgba(255, 255, 255, 0.08);
            background: rgba(20, 27, 45, 0.6);
            backdrop-filter: blur(20px);
            border-radius: 20px;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
            width: 100%;
            max-width: 420px;
            padding: 40px 30px;
            position: relative;
            z-index: 10;
        }

        .brand-logo {
            font-family: 'Outfit', sans-serif;
            font-weight: 800;
            background: linear-gradient(135deg, #a78bfa 0%, #6366f1 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-size: 2.2rem;
            letter-spacing: -1px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .form-control-passcode {
            background: rgba(15, 23, 42, 0.5) !important;
            border: 1px solid rgba(255, 255, 255, 0.1) !important;
            color: #ffffff !important;
            font-family: monospace;
            font-size: 1.4rem;
            letter-spacing: 6px;
            text-align: center;
            border-radius: 12px !important;
            padding: 12px !important;
            transition: all 0.3s ease !important;
        }

        .form-control-passcode:focus {
            border-color: #6366f1 !important;
            box-shadow: 0 0 15px rgba(99, 102, 241, 0.3) !important;
        }

        .btn-auth {
            background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
            border: none;
            color: white;
            padding: 14px;
            border-radius: 12px;
            font-weight: 600;
            font-size: 1rem;
            box-shadow: 0 4px 15px rgba(99, 102, 241, 0.3);
            transition: all 0.3s ease;
        }

        .btn-auth:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(99, 102, 241, 0.5);
            background: linear-gradient(135deg, #818cf8 0%, #4338ca 100%);
        }

        .btn-auth:active {
            transform: translateY(0);
        }

        .text-accent-glow {
            color: #a78bfa;
            text-shadow: 0 0 8px rgba(167, 139, 250, 0.4);
        }
    </style>
</head>
<body>
    <div class="glow-circle-1"></div>
    <div class="glow-circle-2"></div>

    <div class="login-card text-center">
        <!-- Logo -->
        <div class="brand-logo mb-2">
            <i class="bi bi-shield-lock-fill text-accent-glow"></i> RAZOR.AI
        </div>
        
        <p class="text-muted text-sm mb-4">Personal Job Automation Dashboard</p>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger border-0 text-sm mb-4 py-2.5" style="background: rgba(239, 68, 68, 0.1); color: #f87171; border-radius: 10px;">
                <i class="bi bi-exclamation-triangle-fill me-1"></i> @ViewBag.Error
            </div>
        }

        <form method="post" asp-controller="Login" asp-action="Submit">
            <div class="mb-4">
                <label class="form-label d-block text-muted text-start text-xs uppercase fw-bold mb-2" style="letter-spacing: 1px;">Enter Passcode</label>
                <input type="password" name="passcode" class="form-control form-control-passcode" placeholder="••••••••••" required autocomplete="off" />
            </div>

            <button type="submit" class="btn btn-auth w-100 mb-3">
                <i class="bi bi-unlock-fill me-1"></i> Unlock Dashboard
            </button>
        </form>

        <div class="text-xs text-muted mt-4">
            Authorized users only. System access is monitored.
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
