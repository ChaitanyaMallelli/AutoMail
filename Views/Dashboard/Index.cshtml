@model List<JobAutomation.Models.JobPost>
@{
    ViewData["Title"] = "Dashboard";
    ViewData["Subtitle"] = "Your job application pipeline at a glance";
}

<style>
    /* ── Design tokens ── */
    :root {
        --bg-base:           #09090b;
        --bg-elevated:       #111118;
        --bg-card:           #16161f;
        --border:            rgba(255,255,255,0.07);
        --border-hover:      rgba(124,58,237,0.35);
        --accent-violet:     #7c3aed;
        --accent-indigo:     #6366f1;
        --accent-pink:       #ec4899;
        --grad-primary:      linear-gradient(135deg,#7c3aed 0%,#6366f1 100%);
        --grad-hot:          linear-gradient(135deg,#ec4899 0%,#7c3aed 100%);
        --glow-violet:       0 0 20px rgba(124,58,237,0.35);
        --glow-sm:           0 0 12px rgba(124,58,237,0.20);
        --text-primary:      #f4f4f5;
        --text-secondary:    #a1a1aa;
        --text-muted:        #52525b;
        --success:           #22c55e;
        --success-bg:        rgba(34,197,94,0.12);
        --warning:           #f59e0b;
        --warning-bg:        rgba(245,158,11,0.12);
        --danger:            #ef4444;
        --danger-bg:         rgba(239,68,68,0.12);
        --info:              #3b82f6;
        --info-bg:           rgba(59,130,246,0.12);
        --r-sm:  6px;
        --r-md:  10px;
        --r-lg:  14px;
        --r-xl:  20px;
    }

    /* ── Base ── */
    body { background: var(--bg-base); font-family: Inter,-apple-system,sans-serif; color: var(--text-primary); }

    /* ── Page header ── */
    .dash-header-title {
        font-size: 24px;
        font-weight: 800;
        letter-spacing: -0.6px;
        color: var(--text-primary);
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .dash-header-icon {
        width: 36px; height: 36px;
        border-radius: var(--r-md);
        background: var(--grad-primary);
        display: flex; align-items: center; justify-content: center;
        box-shadow: var(--glow-sm);
        font-size: 16px;
        color: #fff;
        flex-shrink: 0;
    }
    .dash-header-subtitle { font-size: 13px; color: var(--text-muted); margin-top: 3px; }

    /* ── Buttons ── */
    .btn-violet {
        background: var(--grad-primary);
        color: #fff;
        border: none;
        border-radius: var(--r-md);
        padding: 9px 18px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        transition: box-shadow .2s, opacity .2s;
    }
    .btn-violet:hover { box-shadow: var(--glow-violet); opacity: .92; color: #fff; }

    .btn-ghost {
        background: rgba(255,255,255,0.05);
        color: var(--text-secondary);
        border: 1px solid var(--border);
        border-radius: var(--r-md);
        padding: 9px 18px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        transition: border-color .2s, background .2s, color .2s;
    }
    .btn-ghost:hover { border-color: var(--border-hover); background: rgba(124,58,237,0.08); color: var(--text-primary); }

    /* ── Stat cards ── */
    .stat-grid { display: grid; grid-template-columns: repeat(6,1fr); gap: 12px; margin-bottom: 28px; }
    @@media(max-width:1199px){ .stat-grid{ grid-template-columns: repeat(3,1fr); } }
    @@media(max-width:767px) { .stat-grid{ grid-template-columns: repeat(2,1fr); } }

    .stat-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--r-lg);
        padding: 18px 16px 16px;
        position: relative;
        overflow: hidden;
        transition: border-color .2s, box-shadow .2s;
    }
    .stat-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 3px;
        border-radius: var(--r-lg) var(--r-lg) 0 0;
    }
    .stat-card:hover { border-color: var(--border-hover); box-shadow: var(--glow-sm); }

    .stat-card-total::before    { background: var(--grad-primary); }
    .stat-card-pending::before  { background: linear-gradient(90deg,#f59e0b,#fbbf24); }
    .stat-card-sent::before     { background: linear-gradient(90deg,#22c55e,#4ade80); }
    .stat-card-interview::before{ background: linear-gradient(90deg,#3b82f6,#60a5fa); }
    .stat-card-offers::before   { background: linear-gradient(90deg,#10b981,#34d399); }
    .stat-card-response::before { background: var(--grad-hot); }

    .stat-icon {
        width: 38px; height: 38px;
        border-radius: var(--r-md);
        display: flex; align-items: center; justify-content: center;
        font-size: 16px;
        margin-bottom: 12px;
        color: #fff;
        flex-shrink: 0;
    }
    .stat-icon-total    { background: rgba(99,102,241,0.18); }
    .stat-icon-pending  { background: rgba(245,158,11,0.18); }
    .stat-icon-sent     { background: rgba(34,197,94,0.18); }
    .stat-icon-interview{ background: rgba(59,130,246,0.18); }
    .stat-icon-offers   { background: rgba(16,185,129,0.18); }
    .stat-icon-response { background: rgba(168,85,247,0.18); }

    .stat-value {
        font-size: 28px;
        font-weight: 800;
        letter-spacing: -1px;
        color: var(--text-primary);
        line-height: 1;
    }
    .stat-value-gradient {
        background: var(--grad-hot);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }
    .stat-label {
        font-size: 12px;
        font-weight: 500;
        color: var(--text-muted);
        margin-top: 5px;
        text-transform: uppercase;
        letter-spacing: .5px;
    }

    /* ── Tabs ── */
    .dash-tabs {
        display: flex;
        gap: 4px;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--r-xl);
        padding: 5px;
        width: fit-content;
        margin-bottom: 20px;
    }
    .dash-tabs .nav-link {
        border: none;
        border-radius: calc(var(--r-xl) - 3px);
        padding: 8px 20px;
        font-size: 13px;
        font-weight: 600;
        color: var(--text-muted);
        background: transparent;
        transition: all .2s;
        white-space: nowrap;
        cursor: pointer;
    }
    .dash-tabs .nav-link:hover { color: var(--text-secondary); background: rgba(255,255,255,0.04); }
    .dash-tabs .nav-link.active { background: var(--grad-primary); color: #fff; box-shadow: var(--glow-sm); }
    .dash-tabs .nav-link .tab-count {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 20px;
        height: 18px;
        border-radius: 9px;
        background: rgba(255,255,255,0.18);
        font-size: 10px;
        font-weight: 700;
        padding: 0 5px;
        margin-left: 6px;
    }

    /* ── Filter panel ── */
    .filter-panel {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--r-lg);
        padding: 14px 16px;
        margin-bottom: 16px;
    }
    .filter-panel .form-control,
    .filter-panel .form-select {
        background: var(--bg-elevated);
        border: 1px solid var(--border);
        border-radius: var(--r-md);
        color: var(--text-primary);
        font-size: 13px;
        height: 38px;
        transition: border-color .2s, box-shadow .2s;
    }
    .filter-panel .form-control::placeholder { color: var(--text-muted); }
    .filter-panel .form-control:focus,
    .filter-panel .form-select:focus {
        background: var(--bg-elevated);
        border-color: var(--border-hover);
        box-shadow: var(--glow-sm);
        color: var(--text-primary);
        outline: none;
    }
    .filter-panel .form-select option { background: #1e1e2e; color: var(--text-primary); }
    .filter-panel .input-group-text {
        background: var(--bg-elevated);
        border: 1px solid var(--border);
        border-right: none;
        border-radius: var(--r-md) 0 0 var(--r-md);
        color: var(--text-muted);
    }
    .filter-panel .input-group .form-control {
        border-left: none;
        border-radius: 0 var(--r-md) var(--r-md) 0;
    }
    .filter-panel .input-group .form-control:focus { border-left: none; }

    /* ── Glass panel / table container ── */
    .glass-panel {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--r-lg);
        overflow: hidden;
    }

    /* ── Table ── */
    .dash-table { width: 100%; border-collapse: separate; border-spacing: 0; }
    .dash-table thead th {
        background: var(--bg-elevated);
        color: var(--text-muted);
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .7px;
        padding: 12px 16px;
        border-bottom: 1px solid var(--border);
        position: sticky; top: 0; z-index: 2;
        white-space: nowrap;
    }
    .dash-table tbody td {
        padding: 13px 16px;
        border-bottom: 1px solid var(--border);
        vertical-align: middle;
        font-size: 13px;
        color: var(--text-secondary);
    }
    .dash-table tbody tr:last-child td { border-bottom: none; }
    .dash-table tbody tr { transition: background .15s; }
    .dash-table tbody tr:hover { background: rgba(124,58,237,0.05); }
    .dash-table tbody tr:hover .company-name { color: #a78bfa; }

    /* Company cell */
    .company-cell { display: flex; align-items: center; gap: 10px; }
    .company-avatar {
        width: 32px; height: 32px;
        border-radius: var(--r-sm);
        display: flex; align-items: center; justify-content: center;
        font-size: 13px; font-weight: 800;
        flex-shrink: 0;
        color: #fff;
    }
    .avatar-a { background: linear-gradient(135deg,#6366f1,#8b5cf6); }
    .avatar-c { background: linear-gradient(135deg,#ec4899,#f43f5e); }
    .avatar-e { background: linear-gradient(135deg,#f59e0b,#ef4444); }
    .avatar-g { background: linear-gradient(135deg,#10b981,#06b6d4); }
    .avatar-i { background: linear-gradient(135deg,#3b82f6,#6366f1); }
    .avatar-k { background: linear-gradient(135deg,#a855f7,#ec4899); }
    .company-avatar:not([class*="avatar-a"]):not([class*="avatar-c"]):not([class*="avatar-e"]):not([class*="avatar-g"]):not([class*="avatar-i"]):not([class*="avatar-k"]) {
        background: linear-gradient(135deg,#7c3aed,#6366f1);
    }
    .company-name { font-weight: 700; font-size: 13px; color: var(--text-primary); transition: color .15s; }
    .role-text { color: var(--text-secondary); font-size: 13px; }
    .date-text { color: var(--text-muted); font-size: 12px; white-space: nowrap; }

    /* Match % bar */
    .match-cell { display: flex; align-items: center; gap: 8px; }
    .match-bar-wrap {
        flex: 1;
        height: 5px;
        background: rgba(255,255,255,0.06);
        border-radius: 99px;
        overflow: hidden;
        min-width: 48px;
    }
    .match-bar-fill { height: 100%; border-radius: 99px; transition: width .4s ease; }
    .match-bar-fill.hi  { background: linear-gradient(90deg,#22c55e,#4ade80); }
    .match-bar-fill.mid { background: linear-gradient(90deg,#f59e0b,#fbbf24); }
    .match-bar-fill.lo  { background: linear-gradient(90deg,#ef4444,#f87171); }
    .match-pct { font-size: 12px; font-weight: 700; white-space: nowrap; min-width: 34px; text-align: right; }
    .match-pct.hi  { color: var(--success); }
    .match-pct.mid { color: var(--warning); }
    .match-pct.lo  { color: var(--danger); }

    /* Status badges */
    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 4px 10px;
        border-radius: 99px;
        font-size: 11px;
        font-weight: 600;
        white-space: nowrap;
        border: 1px solid transparent;
    }
    .sb-pending      { background: rgba(100,116,139,0.15); color: #94a3b8; border-color: rgba(100,116,139,0.2); }
    .sb-ready        { background: var(--info-bg);    color: #60a5fa; border-color: rgba(59,130,246,0.25); }
    .sb-approved     { background: rgba(99,102,241,0.12); color: #818cf8; border-color: rgba(99,102,241,0.25); }
    .sb-sent         { background: var(--success-bg); color: #4ade80; border-color: rgba(34,197,94,0.25); }
    .sb-followup     { background: rgba(139,92,246,0.12); color: #a78bfa; border-color: rgba(139,92,246,0.25); }
    .sb-interview    { background: var(--warning-bg); color: #fbbf24; border-color: rgba(245,158,11,0.25); }
    .sb-offered      { background: rgba(16,185,129,0.12); color: #34d399; border-color: rgba(16,185,129,0.25); }
    .sb-rejected     { background: var(--danger-bg);  color: #f87171; border-color: rgba(239,68,68,0.25); }
    .sb-ghosted      { background: rgba(30,30,46,0.7); color: var(--text-muted); border-color: var(--border); }
    .sb-skipped      { background: rgba(82,82,91,0.15); color: #71717a; border-color: rgba(82,82,91,0.2); }
    .sb-saved        { background: var(--info-bg); color: #60a5fa; border-color: rgba(59,130,246,0.2); }
    .sb-failed       { background: var(--danger-bg); color: #f87171; border-color: rgba(239,68,68,0.25); }

    /* Action buttons */
    .action-btn {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 5px 11px;
        border-radius: var(--r-sm);
        font-size: 12px; font-weight: 600;
        border: 1px solid var(--border);
        background: rgba(255,255,255,0.04);
        color: var(--text-secondary);
        cursor: pointer;
        transition: all .15s;
        text-decoration: none;
    }
    .action-btn:hover { border-color: var(--border-hover); background: rgba(124,58,237,0.10); color: var(--text-primary); box-shadow: var(--glow-sm); }
    .action-btn.disabled, .action-btn[disabled] { pointer-events: none; opacity: .55; }
    .action-btn-success { border-color: rgba(34,197,94,0.3); color: var(--success); background: var(--success-bg); }
    .action-btn-success:hover { border-color: rgba(34,197,94,0.5); }
    .action-btn-info  { border-color: rgba(59,130,246,0.3); color: #60a5fa; background: var(--info-bg); }
    .action-btn-info:hover { border-color: rgba(59,130,246,0.5); }

    /* ── Empty state ── */
    .empty-state {
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        padding: 60px 24px; text-align: center;
    }
    .empty-icon-wrap {
        width: 64px; height: 64px;
        border-radius: var(--r-xl);
        background: rgba(124,58,237,0.10);
        border: 1px solid rgba(124,58,237,0.20);
        display: flex; align-items: center; justify-content: center;
        font-size: 26px; color: var(--accent-violet);
        margin-bottom: 18px;
    }
    .empty-state h3 { font-size: 17px; font-weight: 700; color: var(--text-primary); margin-bottom: 6px; }
    .empty-state p  { font-size: 13px; color: var(--text-muted); max-width: 340px; margin-bottom: 20px; }

    /* ── Pagination ── */
    .dash-pagination { display: flex; align-items: center; justify-content: space-between; margin-top: 16px; gap: 12px; flex-wrap: wrap; }
    .dash-pagination .pg-info { font-size: 12px; color: var(--text-muted); }
    .pg-list { display: flex; gap: 4px; list-style: none; margin: 0; padding: 0; }
    .pg-list .pg-item .pg-link {
        display: inline-flex; align-items: center; justify-content: center;
        min-width: 32px; height: 32px;
        border-radius: var(--r-sm);
        background: var(--bg-card);
        border: 1px solid var(--border);
        color: var(--text-secondary);
        font-size: 13px; font-weight: 600;
        text-decoration: none;
        transition: all .15s;
        padding: 0 8px;
    }
    .pg-list .pg-item .pg-link:hover { border-color: var(--border-hover); color: var(--text-primary); background: rgba(124,58,237,0.08); }
    .pg-list .pg-item.active .pg-link { background: var(--grad-primary); border-color: transparent; color: #fff; box-shadow: var(--glow-sm); }
    .pg-list .pg-item.disabled .pg-link { opacity: .35; pointer-events: none; }

    /* ── Scout log status badges ── */
    .sl-badge {
        display: inline-flex; align-items: center; gap: 4px;
        padding: 3px 9px; border-radius: 99px;
        font-size: 11px; font-weight: 600; border: 1px solid transparent;
    }
    .sl-new      { background: rgba(82,82,91,0.18); color: #a1a1aa; border-color: rgba(82,82,91,0.25); }
    .sl-telegram { background: var(--info-bg); color: #38bdf8; border-color: rgba(56,189,248,0.25); }
    .sl-ignored  { background: rgba(30,30,46,0.7); color: var(--text-muted); border-color: var(--border); }
    .sl-applied  { background: var(--success-bg); color: #4ade80; border-color: rgba(34,197,94,0.25); }

    /* ── Skeleton loader ── */
    .skeleton {
        background: linear-gradient(90deg, rgba(255,255,255,0.05) 25%, rgba(255,255,255,0.09) 50%, rgba(255,255,255,0.05) 75%);
        background-size: 200% 100%;
        animation: shimmer 1.5s infinite;
        border-radius: var(--r-sm);
    }
    @@keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }

    .skeleton-row td { padding: 14px 16px !important; }
    .skeleton-line { height: 13px; border-radius: 6px; }

    /* scout board pill */
    .board-pill {
        display: inline-flex; align-items: center;
        padding: 3px 9px; border-radius: 99px;
        font-size: 10px; font-weight: 700;
        background: rgba(2,132,199,0.12);
        color: #38bdf8;
        border: 1px solid rgba(2,132,199,0.25);
    }
    .keyword-pill {
        display: inline-flex; align-items: center;
        padding: 3px 9px; border-radius: 99px;
        font-size: 11px; font-weight: 500;
        background: rgba(255,255,255,0.06);
        color: var(--text-secondary);
        border: 1px solid var(--border);
    }
</style>

@* ── Page header ── *@
<div class="d-flex justify-content-between align-items-start mb-4 gap-3 flex-wrap">
    <div>
        <div class="dash-header-title">
            <div class="dash-header-icon"><i class="bi bi-speedometer2"></i></div>
            Dashboard
        </div>
        <p class="dash-header-subtitle">Monitor and manage your entire job application pipeline</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <button id="btnRunScout" class="btn-ghost">
            <i class="bi bi-search" id="scoutIcon"></i>
            <span id="scoutText">Search Now</span>
        </button>
        <button id="btnStartApply" class="btn-violet">
            <i class="bi bi-link-45deg"></i> Apply from Links
        </button>
        <button id="btnStopApply" class="btn-ghost" style="display:none;">
            <i class="bi bi-stop-circle"></i> Stop
        </button>
        <a href="@Url.Action("Index", "Upload")" class="btn-violet">
            <i class="bi bi-plus-lg"></i> New Job
        </a>
    </div>
</div>

@* ── Auto-Apply from Links — live progress panel ── *@
<div id="applyPanel" class="glass-panel" style="display:none; padding:18px 20px; margin-bottom:24px;">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2" style="margin-bottom:12px;">
        <div style="display:flex; align-items:center; gap:10px;">
            <span id="applyStateDot" class="status-badge sb-pending"><i class="bi bi-lightning-charge-fill"></i> <span id="applyStateText">Idle</span></span>
            <span style="font-size:13px; color:var(--text-secondary);"><span id="applyProcessed">0</span>/<span id="applyTotal">0</span> processed</span>
            <span style="font-size:12px; color:var(--text-muted);">· Gemini today <b id="applyGemini">0/500</b></span>
        </div>
        <div style="display:flex; gap:14px; font-size:12.5px;">
            <span style="color:#4ade80;">✅ Applied <b id="applyApplied">0</b></span>
            <span style="color:#fbbf24;">⏭️ Skipped <b id="applySkipped">0</b></span>
            <span style="color:#f87171;">❌ Failed <b id="applyFailed">0</b></span>
        </div>
    </div>
    <div id="applyEntries" style="max-height:280px; overflow-y:auto; display:flex; flex-direction:column; gap:6px;"></div>
</div>

@* ── Stat cards ── *@
<div class="stat-grid">
    <div class="stat-card stat-card-total">
        <div class="stat-icon stat-icon-total"><i class="bi bi-briefcase-fill"></i></div>
        <div class="stat-value">@ViewBag.TotalJobs</div>
        <div class="stat-label">Total Jobs</div>
    </div>
    <div class="stat-card stat-card-pending">
        <div class="stat-icon stat-icon-pending"><i class="bi bi-hourglass-split"></i></div>
        <div class="stat-value">@ViewBag.PendingJobs</div>
        <div class="stat-label">Pending Review</div>
    </div>
    <div class="stat-card stat-card-sent">
        <div class="stat-icon stat-icon-sent"><i class="bi bi-send-check-fill"></i></div>
        <div class="stat-value">@ViewBag.SentJobs</div>
        <div class="stat-label">Emails Sent</div>
    </div>
    <div class="stat-card stat-card-interview">
        <div class="stat-icon stat-icon-interview"><i class="bi bi-telephone-fill"></i></div>
        <div class="stat-value">@ViewBag.Interviews</div>
        <div class="stat-label">Interviews</div>
    </div>
    <div class="stat-card stat-card-offers">
        <div class="stat-icon stat-icon-offers"><i class="bi bi-award-fill"></i></div>
        <div class="stat-value">@ViewBag.Offers</div>
        <div class="stat-label">Offers</div>
    </div>
    <div class="stat-card stat-card-response">
        <div class="stat-icon stat-icon-response"><i class="bi bi-graph-up-arrow"></i></div>
        <div class="stat-value stat-value-gradient">@ViewBag.ResponseRate%</div>
        <div class="stat-label">Response Rate</div>
    </div>
</div>

@* ── Pill tab nav ── *@
<ul class="nav dash-tabs" id="dashboardTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="applications-tab"
                data-bs-toggle="tab" data-bs-target="#applications"
                type="button" role="tab" aria-controls="applications" aria-selected="true">
            <i class="bi bi-briefcase me-1"></i>Active Applications
            @if (Model.Count > 0)
            {
                <span class="tab-count">@Model.Count</span>
            }
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="scout-logs-tab"
                data-bs-toggle="tab" data-bs-target="#scout-logs"
                type="button" role="tab" aria-controls="scout-logs" aria-selected="false">
            <i class="bi bi-robot me-1"></i>LinkedIn Scout Logs
            <span class="tab-count" id="scoutBadge" style="display:none;"></span>
        </button>
    </li>
</ul>

<div class="tab-content" id="dashboardTabsContent">

    @* ── Tab 1: Active Applications ── *@
    <div class="tab-pane fade show active" id="applications" role="tabpanel" aria-labelledby="applications-tab">

        @* Filter bar *@
        <div class="filter-panel">
            <form method="get" class="row g-2 align-items-center" id="filterForm">
                <div class="col-12 col-md-5">
                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" name="search" id="searchInput"
                               class="form-control"
                               placeholder="Search company or role..."
                               value="@ViewBag.Search"
                               style="padding-left:8px!important;" />
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <select name="status" class="form-select" onchange="document.getElementById('filterForm').submit()">
                        <option value="">All Statuses</option>
                        <option value="Pending"             selected="@(ViewBag.Status == "Pending"             ? "selected" : null)">Pending</option>
                        <option value="EmailGenerated"      selected="@(ViewBag.Status == "EmailGenerated"      ? "selected" : null)">Ready for Review</option>
                        <option value="Sent"                selected="@(ViewBag.Status == "Sent"                ? "selected" : null)">Sent</option>
                        <option value="FollowUpSent"        selected="@(ViewBag.Status == "FollowUpSent"        ? "selected" : null)">Follow-up Sent</option>
                        <option value="InterviewScheduled"  selected="@(ViewBag.Status == "InterviewScheduled"  ? "selected" : null)">Interviewing</option>
                        <option value="Offered"             selected="@(ViewBag.Status == "Offered"             ? "selected" : null)">Offered</option>
                        <option value="Rejected"            selected="@(ViewBag.Status == "Rejected"            ? "selected" : null)">Rejected</option>
                    </select>
                </div>
                <div class="col-6 col-md-3">
                    <select name="sort" class="form-select" onchange="document.getElementById('filterForm').submit()">
                        <option value="">Latest First</option>
                        <option value="company" selected="@(ViewBag.Sort == "company" ? "selected" : null)">Company (A-Z)</option>
                        <option value="role"    selected="@(ViewBag.Sort == "role"    ? "selected" : null)">Role (A-Z)</option>
                        <option value="match"   selected="@(ViewBag.Sort == "match"   ? "selected" : null)">Highest Match %</option>
                    </select>
                </div>
                <div class="col-12 col-md-1 d-flex justify-content-end">
                    <button type="submit" class="btn-violet w-100" style="justify-content:center;height:38px;">
                        <i class="bi bi-funnel-fill"></i>
                    </button>
                </div>
            </form>
        </div>

        @* Applications table *@
        <div class="glass-panel p-0">
            @if (Model.Count == 0)
            {
                <div class="empty-state">
                    <div class="empty-icon-wrap"><i class="bi bi-inbox"></i></div>
                    <h3>No applications found</h3>
                    <p>
                        @if (!string.IsNullOrEmpty(ViewBag.Search as string) || !string.IsNullOrEmpty(ViewBag.Status as string))
                        {
                            <span>Try adjusting your filters, or add a new job.</span>
                        }
                        else
                        {
                            <span>Upload a job post to get started on your pipeline.</span>
                        }
                    </p>
                    <a href="@Url.Action("Index", "Upload")" class="btn-violet">
                        <i class="bi bi-plus-lg"></i> Add First Job
                    </a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="dash-table">
                        <thead>
                            <tr>
                                <th style="width:110px;">Date</th>
                                <th>Company</th>
                                <th>Role</th>
                                <th style="width:140px;">Match %</th>
                                <th style="width:150px;">Status</th>
                                <th style="width:160px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var job in Model)
                            {
                                var firstLetter = !string.IsNullOrEmpty(job.CompanyName) ? job.CompanyName[0].ToString().ToUpper() : "J";
                                var avatarClass = firstLetter[0] switch {
                                    'A' or 'B' => "avatar-a",
                                    'C' or 'D' => "avatar-c",
                                    'E' or 'F' => "avatar-e",
                                    'G' or 'H' => "avatar-g",
                                    'I' or 'J' => "avatar-i",
                                    'K' or 'L' => "avatar-k",
                                    _          => ""
                                };
                                var matchClass = job.SkillMatchPercentage >= 70 ? "hi" : job.SkillMatchPercentage >= 40 ? "mid" : "lo";
                                <tr class="job-row">
                                    <td>
                                        <span class="date-text">@job.CreatedAt.ToIst().ToString("MMM dd, yyyy")</span>
                                    </td>
                                    <td>
                                        <div class="company-cell">
                                            <div class="company-avatar @avatarClass">@firstLetter</div>
                                            <span class="company-name" title="@job.CompanyName">@job.CompanyName</span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="role-text">@job.Role</span>
                                    </td>
                                    <td>
                                        <div class="match-cell">
                                            <div class="match-bar-wrap">
                                                <div class="match-bar-fill @matchClass"
                                                     style="width:@job.SkillMatchPercentage%;"
                                                     role="progressbar"
                                                     aria-valuenow="@job.SkillMatchPercentage"
                                                     aria-valuemin="0" aria-valuemax="100">
                                                </div>
                                            </div>
                                            <span class="match-pct @matchClass">@job.SkillMatchPercentage%</span>
                                        </div>
                                    </td>
                                    <td>
                                        @switch (job.Status)
                                        {
                                            case JobAutomation.Models.JobStatus.Pending:
                                                <span class="status-badge sb-pending"><i class="bi bi-hourglass"></i>Processing</span>
                                                break;
                                            case JobAutomation.Models.JobStatus.EmailGenerated:
                                                <span class="status-badge sb-ready"><i class="bi bi-envelope-check"></i>Ready</span>
                                                break;
                                            case JobAutomation.Models.JobStatus.Approved:
                                                <span class="status-badge sb-approved"><i class="bi bi-check"></i>Approved</span>
                                                break;
                                            case JobAutomation.Models.JobStatus.Sent:
                                                <span class="status-badge sb-sent"><i class="bi bi-send-check"></i>Sent</span>
                                                break;
                                            case JobAutomation.Models.JobStatus.FollowUpSent:
                                                <span class="status-badge sb-followup"><i class="bi bi-arrow-clockwise"></i>Follow-up</span>
                                                break;
                                            case JobAutomation.Models.JobStatus.InterviewScheduled:
                                                <span class="status-badge sb-interview"><i class="bi bi-telephone"></i>Interview</span>
                                                break;
                                            case JobAutomation.Models.JobStatus.Offered:
                                                <span class="status-badge sb-offered"><i class="bi bi-award"></i>Offered</span>
                                                break;
                                            case JobAutomation.Models.JobStatus.Rejected:
                                                <span class="status-badge sb-rejected"><i class="bi bi-x-circle"></i>Rejected</span>
                                                break;
                                            case JobAutomation.Models.JobStatus.Ghosted:
                                                <span class="status-badge sb-ghosted"><i class="bi bi-question-circle"></i>Ghosted</span>
                                                break;
                                            case JobAutomation.Models.JobStatus.Skipped:
                                                <span class="status-badge sb-skipped">Skipped</span>
                                                break;
                                            case JobAutomation.Models.JobStatus.SavedForLater:
                                                <span class="status-badge sb-saved"><i class="bi bi-bookmark"></i>Saved</span>
                                                break;
                                            case JobAutomation.Models.JobStatus.Failed:
                                                <span class="status-badge sb-failed"><i class="bi bi-exclamation-triangle"></i>Failed</span>
                                                break;
                                            default:
                                                <span class="status-badge sb-skipped">@job.Status</span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center gap-1 flex-wrap">
                                            <a href="@Url.Action("Preview", "Email", new { id = job.Id })"
                                               class="action-btn action-btn-info"
                                               title="View email preview">
                                                <i class="bi bi-eye"></i>View
                                            </a>
                                            @if (job.GeneratedEmail?.OpenedAt.HasValue == true)
                                            {
                                                <span class="action-btn action-btn-success disabled"
                                                      title="Email opened @job.GeneratedEmail.OpenedAt.ToIstString("MMM dd, HH:mm", true)">
                                                    <i class="bi bi-eye-fill"></i>
                                                </span>
                                            }
                                            @if (job.GeneratedEmail?.RepliedAt.HasValue == true)
                                            {
                                                var replyIcon = job.GeneratedEmail.ReplyClassification switch {
                                                    "interview"  => "bi-telephone-fill",
                                                    "rejected"   => "bi-x-circle-fill",
                                                    "interested" => "bi-star-fill",
                                                    _            => "bi-envelope-open-fill"
                                                };
                                                <span class="action-btn disabled"
                                                      title="Reply: @job.GeneratedEmail.ReplyClassification">
                                                    <i class="bi @replyIcon"></i>
                                                </span>
                                            }
                                            @* Temporarily disabled Co-Pilot
                                            <a href="@Url.Action("CoPilot", "Interview", new { id = job.Id })" class="action-btn" target="_blank">
                                                <i class="bi bi-mic-fill"></i> Co-Pilot
                                            </a>
                                            *@
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        @* Pagination *@
        @if (ViewBag.TotalPages > 1)
        {
            var currentPage = (int)ViewBag.Page;
            var totalPages  = (int)ViewBag.TotalPages;
            <nav class="dash-pagination">
                <span class="pg-info">
                    Showing @(((currentPage - 1) * 20) + 1)–@(Math.Min(currentPage * 20, (int)ViewBag.TotalFiltered)) of @ViewBag.TotalFiltered jobs
                </span>
                <ul class="pg-list">
                    <li class="pg-item @(currentPage == 1 ? "disabled" : "")">
                        <a class="pg-link" href="?page=@(currentPage - 1)&search=@ViewBag.Search&status=@ViewBag.Status&sort=@ViewBag.Sort">&#8249;</a>
                    </li>
                    @for (int p = Math.Max(1, currentPage - 2); p <= Math.Min(totalPages, currentPage + 2); p++)
                    {
                        <li class="pg-item @(p == currentPage ? "active" : "")">
                            <a class="pg-link" href="?page=@p&search=@ViewBag.Search&status=@ViewBag.Status&sort=@ViewBag.Sort">@p</a>
                        </li>
                    }
                    <li class="pg-item @(currentPage == totalPages ? "disabled" : "")">
                        <a class="pg-link" href="?page=@(currentPage + 1)&search=@ViewBag.Search&status=@ViewBag.Status&sort=@ViewBag.Sort">&#8250;</a>
                    </li>
                </ul>
            </nav>
        }
    </div>

    @* ── Tab 2: LinkedIn Scout Logs (lazy-loaded) ── *@
    <div class="tab-pane fade" id="scout-logs" role="tabpanel" aria-labelledby="scout-logs-tab">
        <div class="glass-panel p-0" id="scoutLogsPanel">

            @* Skeleton loader *@
            <div id="scoutLogsLoading">
                <table class="dash-table">
                    <thead>
                        <tr>
                            <th style="width:120px;">Date</th>
                            <th style="width:90px;">Board</th>
                            <th style="width:130px;">Keyword</th>
                            <th style="width:160px;">Status</th>
                            <th>Text Preview</th>
                            <th style="width:190px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int sk = 0; sk < 5; sk++)
                        {
                            <tr class="skeleton-row">
                                <td><div class="skeleton skeleton-line" style="width:80px;"></div></td>
                                <td><div class="skeleton skeleton-line" style="width:60px;"></div></td>
                                <td><div class="skeleton skeleton-line" style="width:90px;"></div></td>
                                <td><div class="skeleton skeleton-line" style="width:100px;"></div></td>
                                <td><div class="skeleton skeleton-line" style="width:100%;max-width:320px;"></div></td>
                                <td><div class="skeleton skeleton-line" style="width:120px;float:right;"></div></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @* Actual content (shown after load) *@
            <div id="scoutLogsContent" style="display:none;">
                <div class="empty-state" id="scoutLogsEmpty" style="display:none;">
                    <div class="empty-icon-wrap"><i class="bi bi-robot"></i></div>
                    <h3>No scout logs yet</h3>
                    <p>The background LinkedIn scout hasn't run yet, or no matches were found.</p>
                </div>
                <div class="table-responsive" id="scoutLogsTable" style="display:none;">
                    <table class="dash-table">
                        <thead>
                            <tr>
                                <th style="width:120px;">Date</th>
                                <th style="width:90px;">Board</th>
                                <th style="width:130px;">Keyword</th>
                                <th style="width:160px;">Status</th>
                                <th>Text Preview</th>
                                <th class="text-end pe-4" style="width:200px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="scoutLogsTbody"></tbody>
                    </table>
                </div>
            </div>

        </div>
    </div>

</div>

@section Scripts {
    <script>
        // ── Apply from Links File: start / stop + live progress ─────
        (function () {
            const startBtn = document.getElementById('btnStartApply');
            const stopBtn  = document.getElementById('btnStopApply');
            const panel    = document.getElementById('applyPanel');
            if (!startBtn) return;
            let pollTimer = null;

            const badgeClass = s => s === 'Applied' ? 'sb-sent' : (s === 'Skipped' ? 'sb-saved' : 'sb-failed');
            const rowIcon    = s => s === 'Applied' ? 'bi-check-circle' : (s === 'Skipped' ? 'bi-skip-forward' : 'bi-x-circle');

            async function poll() {
                try {
                    const r = await fetch('/Dashboard/LinksApplyStatus');
                    if (!r.ok) return;
                    const d = await r.json();

                    if (d.total > 0 || d.running) panel.style.display = '';
                    document.getElementById('applyProcessed').textContent = d.processed;
                    document.getElementById('applyTotal').textContent     = d.total;
                    document.getElementById('applyApplied').textContent    = d.applied;
                    document.getElementById('applySkipped').textContent    = d.skipped;
                    document.getElementById('applyFailed').textContent     = d.failed;
                    if (d.geminiMax) document.getElementById('applyGemini').textContent = d.geminiUsed + '/' + d.geminiMax;

                    const st = document.getElementById('applyStateText');
                    const dot = document.getElementById('applyStateDot');
                    if (d.running) {
                        st.textContent = 'Running';
                        dot.className = 'status-badge sb-ready';
                        startBtn.style.display = 'none';
                        stopBtn.style.display = '';
                    } else {
                        st.textContent = d.processed > 0 ? 'Finished' : 'Idle';
                        dot.className = 'status-badge ' + (d.processed > 0 ? 'sb-sent' : 'sb-pending');
                        startBtn.style.display = '';
                        stopBtn.style.display = 'none';
                        if (pollTimer) { clearInterval(pollTimer); pollTimer = null; }
                    }

                    document.getElementById('applyEntries').innerHTML = (d.entries || []).map(e =>
                        `<div class="d-flex align-items-center gap-2" style="font-size:12.5px;border:1px solid var(--border);border-radius:8px;padding:6px 10px;">
                            <span class="status-badge ${badgeClass(e.status)}"><i class="bi ${rowIcon(e.status)}"></i> ${e.status}</span>
                            <span style="color:var(--text-primary);font-weight:600;">${e.company}</span>
                            <span style="color:var(--text-muted);">— ${e.role}</span>
                            <span style="color:var(--text-muted);margin-left:auto;text-align:right;">${e.detail || ''} · ${e.time}</span>
                         </div>`).join('');
                } catch (e) { /* ignore transient poll errors */ }
            }

            function startPolling() { if (!pollTimer) { poll(); pollTimer = setInterval(poll, 1500); } }

            startBtn.addEventListener('click', async () => {
                startBtn.disabled = true;
                try {
                    const r = await fetch('/Dashboard/StartLinksApply', { method: 'POST' });
                    const d = await r.json();
                    if (!d.success) { alert(d.message || 'Could not start.'); }
                    else { panel.style.display = ''; startPolling(); }
                } catch (e) { alert('Failed to start the run.'); }
                finally { startBtn.disabled = false; }
            });

            stopBtn.addEventListener('click', async () => {
                stopBtn.disabled = true;
                try { await fetch('/Dashboard/StopLinksApply', { method: 'POST' }); } catch (e) {}
                stopBtn.disabled = false;
            });

            // Resume the live view if a run is already active when the page loads.
            startPolling();
        })();

        // ── Web-apply handler for scouted jobs ──────────────────────
        document.querySelectorAll('.btn-web-apply').forEach(btn => {
            btn.addEventListener('click', async function () {
                const jobId = this.dataset.jobId;
                const originalHtml = this.innerHTML;
                this.disabled = true;
                this.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Starting...';

                try {
                    const response = await fetch(`@Url.Action("ApplyScoutedJob", "Dashboard")?id=${jobId}`, {
                        method: 'POST'
                    });

                    const result = await response.json();
                    if (result.success) {
                        window.location.href = result.redirectUrl;
                    } else {
                        alert('Failed to start: ' + (result.message || 'Unknown error'));
                        this.disabled = false;
                        this.innerHTML = originalHtml;
                    }
                } catch (err) {
                    console.error(err);
                    alert('Request failed. Check console for details.');
                    this.disabled = false;
                    this.innerHTML = originalHtml;
                }
            });
        });

        // ── Run Scout Now handler ────────────────────────────────────
        function attachScoutHandler(btnId) {
            const btn = document.getElementById(btnId);
            if (!btn) return;
            btn.addEventListener('click', async function () {
                const icon   = document.getElementById('scoutIcon');
                const textEl = document.getElementById('scoutText');
                const origIcon = icon ? icon.className : '';
                const origText = textEl ? textEl.textContent : '';

                this.disabled = true;
                if (icon) icon.className = 'spinner-border spinner-border-sm';
                if (textEl) textEl.textContent = 'Scouting...';

                try {
                    const response = await fetch('@Url.Action("RunScoutNow", "Dashboard")', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' }
                    });

                    if (response.ok) {
                        this.style.background = 'var(--success-bg)';
                        this.style.borderColor = 'rgba(34,197,94,0.4)';
                        this.style.color = 'var(--success)';
                        if (icon) icon.className = 'bi bi-check-circle';
                        if (textEl) textEl.textContent = 'Scout Complete!';

                        setTimeout(() => {
                            this.style.background = '';
                            this.style.borderColor = '';
                            this.style.color = '';
                            this.disabled = false;
                            if (icon) icon.className = origIcon;
                            if (textEl) textEl.textContent = origText;
                        }, 3000);
                    } else {
                        throw new Error('Scout request failed');
                    }
                } catch (error) {
                    console.error(error);
                    this.style.background = 'var(--danger-bg)';
                    this.style.borderColor = 'rgba(239,68,68,0.4)';
                    this.style.color = 'var(--danger)';
                    if (icon) icon.className = 'bi bi-exclamation-triangle';
                    if (textEl) textEl.textContent = 'Scout Failed';

                    setTimeout(() => {
                        this.style.background = '';
                        this.style.borderColor = '';
                        this.style.color = '';
                        this.disabled = false;
                        if (icon) icon.className = origIcon;
                        if (textEl) textEl.textContent = origText;
                    }, 3000);
                }
            });
        }

        attachScoutHandler('btnRunScout');

        // ── Lazy-load Scout Logs on first tab open ───────────────────
        let scoutLogsLoaded = false;

        function scoutStatusHtml(status) {
            const map = {
                'New':             '<span class="sl-badge sl-new">New</span>',
                'SentToTelegram':  '<span class="sl-badge sl-telegram"><i class="bi bi-telegram me-1"></i>Sent to Telegram</span>',
                'IgnoredByGemini': '<span class="sl-badge sl-ignored"><i class="bi bi-x-circle me-1"></i>Ignored by AI</span>',
                'Applied':         '<span class="sl-badge sl-applied"><i class="bi bi-check-circle-fill me-1"></i>Applied</span>',
            };
            return map[status] || `<span class="sl-badge sl-new">${status}</span>`;
        }

        document.getElementById('scout-logs-tab').addEventListener('shown.bs.tab', async function () {
            if (scoutLogsLoaded) return;
            scoutLogsLoaded = true;
            try {
                const res  = await fetch('@Url.Action("GetScoutLogs", "Dashboard")');
                const jobs = await res.json();

                document.getElementById('scoutLogsLoading').style.display = 'none';

                if (jobs.length === 0) {
                    document.getElementById('scoutLogsEmpty').style.display = '';
                    document.getElementById('scoutLogsContent').style.display = '';
                    return;
                }

                const badge = document.getElementById('scoutBadge');
                badge.textContent = jobs.length;
                badge.style.display = '';

                const tbody = document.getElementById('scoutLogsTbody');
                tbody.innerHTML = jobs.map(j => {
                    const statusHtml = scoutStatusHtml(j.status);
                    const applyBtn = (j.status === 'New' || j.status === 'SentToTelegram')
                        ? `<button type="button" class="action-btn btn-web-apply" style="background:linear-gradient(135deg,#7c3aed,#6366f1);border:none;color:#fff;" data-job-id="${j.id}"><i class="bi bi-send-fill"></i>Apply</button>`
                        : j.status === 'Applied'
                            ? `<button class="action-btn action-btn-success disabled" disabled><i class="bi bi-check-circle-fill"></i>Applied</button>`
                            : '';
                    const preview = (j.rawPreview || '').replace(/"/g, '&quot;');
                    return `<tr>
                        <td class="align-middle"><span class="date-text">${j.createdAt}</span></td>
                        <td class="align-middle"><span class="board-pill">${j.board}</span></td>
                        <td class="align-middle"><span class="keyword-pill">${j.keyword || ''}</span></td>
                        <td class="align-middle">${statusHtml}</td>
                        <td class="align-middle"><span style="font-size:12px;color:var(--text-muted);" title="${preview}">${j.rawPreview || ''}</span></td>
                        <td class="align-middle text-end pe-4">
                            <div class="d-flex justify-content-end gap-2 flex-wrap">
                                <a href="${j.url}" target="_blank" class="action-btn action-btn-info"><i class="bi bi-box-arrow-up-right"></i>Post</a>
                                ${applyBtn}
                            </div>
                        </td>
                    </tr>`;
                }).join('');

                document.getElementById('scoutLogsTable').style.display = '';
                document.getElementById('scoutLogsContent').style.display = '';

                // Wire apply buttons in dynamically rendered rows
                document.querySelectorAll('#scoutLogsTbody .btn-web-apply').forEach(btn => {
                    btn.addEventListener('click', async function () {
                        const jobId = this.dataset.jobId;
                        const originalHtml = this.innerHTML;
                        this.disabled = true;
                        this.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Starting...';
                        try {
                            const r = await fetch(`@Url.Action("ApplyScoutedJob", "Dashboard")?id=${jobId}`, { method: 'POST' });
                            const result = await r.json();
                            if (result.success) {
                                window.location.href = result.redirectUrl;
                            } else {
                                alert('Failed: ' + (result.message || 'Unknown'));
                                this.disabled = false;
                                this.innerHTML = originalHtml;
                            }
                        } catch (err) {
                            alert('Request failed.');
                            this.disabled = false;
                            this.innerHTML = originalHtml;
                        }
                    });
                });
            } catch (err) {
                console.error('Failed to load scout logs', err);
                document.getElementById('scoutLogsLoading').innerHTML =
                    '<div class="empty-state"><div class="empty-icon-wrap" style="background:var(--danger-bg);border-color:rgba(239,68,68,.2);color:var(--danger);"><i class="bi bi-exclamation-triangle"></i></div><h3>Failed to load logs</h3><p>Check console for details.</p></div>';
            }
        });
    </script>
}
