@model List<JobAutomation.Models.JobPost>
@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-2">
    <h2><i class="bi bi-speedometer2 me-2"></i> Dashboard</h2>
    <a href="@Url.Action("Index", "Upload")" class="btn btn-glow">
        <i class="bi bi-plus-lg"></i> New Job
    </a>
</div>

<div class="row mb-4 g-3">
    <div class="col-md-2 col-sm-6">
        <div class="stat-card">
            <div class="stat-icon"><i class="bi bi-briefcase"></i></div>
            <div class="stat-value">@ViewBag.TotalJobs</div>
            <div class="stat-label">Total Jobs</div>
        </div>
    </div>
    <div class="col-md-2 col-sm-6">
        <div class="stat-card">
            <div class="stat-icon bg-warning text-dark"><i class="bi bi-hourglass-split"></i></div>
            <div class="stat-value">@ViewBag.PendingJobs</div>
            <div class="stat-label">Pending Review</div>
        </div>
    </div>
    <div class="col-md-2 col-sm-6">
        <div class="stat-card">
            <div class="stat-icon bg-success"><i class="bi bi-send-check"></i></div>
            <div class="stat-value">@ViewBag.SentJobs</div>
            <div class="stat-label">Emails Sent</div>
        </div>
    </div>
    <div class="col-md-2 col-sm-6">
        <div class="stat-card">
            <div class="stat-icon bg-info"><i class="bi bi-telephone"></i></div>
            <div class="stat-value">@ViewBag.Interviews</div>
            <div class="stat-label">Interviews</div>
        </div>
    </div>
    <div class="col-md-2 col-sm-6">
        <div class="stat-card">
            <div class="stat-icon" style="background-color: var(--color-success);"><i class="bi bi-award"></i></div>
            <div class="stat-value">@ViewBag.Offers</div>
            <div class="stat-label">Offers</div>
        </div>
    </div>
    <div class="col-md-2 col-sm-6">
        <div class="stat-card">
            <div class="stat-icon bg-primary"><i class="bi bi-graph-up"></i></div>
            <div class="stat-value">@ViewBag.ResponseRate%</div>
            <div class="stat-label">Response Rate</div>
        </div>
    </div>
</div>

<!-- Filters & Search -->
<div class="glass-panel mb-4 p-3">
    <form method="get" class="row g-3 align-items-center">
        <div class="col-md-5">
            <div class="input-group">
                <span class="input-group-text bg-transparent text-muted"><i class="bi bi-search"></i></span>
                <input type="text" name="search" class="form-control" placeholder="Search company, role..." value="@ViewBag.Search">
            </div>
        </div>
        <div class="col-md-3">
            <select name="status" class="form-select">
                <option value="">All Statuses</option>
                <option value="Pending" selected="@(ViewBag.Status == "Pending" ? "selected" : null)">Pending</option>
                <option value="EmailGenerated" selected="@(ViewBag.Status == "EmailGenerated" ? "selected" : null)">Ready for Review</option>
                <option value="Sent" selected="@(ViewBag.Status == "Sent" ? "selected" : null)">Sent</option>
                <option value="FollowUpSent" selected="@(ViewBag.Status == "FollowUpSent" ? "selected" : null)">Follow-up Sent</option>
                <option value="InterviewScheduled" selected="@(ViewBag.Status == "InterviewScheduled" ? "selected" : null)">Interviewing</option>
                <option value="Offered" selected="@(ViewBag.Status == "Offered" ? "selected" : null)">Offered</option>
                <option value="Rejected" selected="@(ViewBag.Status == "Rejected" ? "selected" : null)">Rejected</option>
            </select>
        </div>
        <div class="col-md-3">
            <select name="sort" class="form-select">
                <option value="">Latest First</option>
                <option value="company" selected="@(ViewBag.Sort == "company" ? "selected" : null)">Company (A-Z)</option>
                <option value="role" selected="@(ViewBag.Sort == "role" ? "selected" : null)">Role (A-Z)</option>
                <option value="match" selected="@(ViewBag.Sort == "match" ? "selected" : null)">Highest Match %</option>
            </select>
        </div>
        <div class="col-md-1 text-end">
            <button type="submit" class="btn btn-primary w-100">Filter</button>
        </div>
    </form>
</div>

<!-- Job Posts Table -->
<div class="glass-panel p-0">
    <div class="table-responsive">
        @if (Model.Count == 0)
        {
            <div class="p-5 text-center text-muted">
                <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                <h5>No job posts found</h5>
                <p>Upload a screenshot, PDF, or text job post to get started.</p>
            </div>
        }
        else
        {
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Company</th>
                        <th>Role</th>
                        <th>Match %</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var job in Model)
                    {
                        <tr>
                            <td>@job.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td class="fw-bold">@job.CompanyName</td>
                            <td>@job.Role</td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="progress flex-grow-1 me-2" style="height: 6px;">
                                        <div class="progress-bar @(job.SkillMatchPercentage >= 70 ? "bg-success" : job.SkillMatchPercentage >= 40 ? "bg-warning" : "bg-danger")"
                                             role="progressbar" style="width: @job.SkillMatchPercentage%"
                                             aria-valuenow="@job.SkillMatchPercentage" aria-valuemin="0" aria-valuemax="100"></div>
                                    </div>
                                    <span class="small text-muted">@job.SkillMatchPercentage%</span>
                                </div>
                            </td>
                            <td>
                                @switch (job.Status)
                                {
                                    case JobAutomation.Models.JobStatus.Pending:
                                        <span class="badge bg-secondary">Processing</span>
                                        break;
                                    case JobAutomation.Models.JobStatus.EmailGenerated:
                                        <span class="badge bg-info text-dark">Ready for Review</span>
                                        break;
                                    case JobAutomation.Models.JobStatus.Approved:
                                        <span class="badge bg-primary">Approved</span>
                                        break;
                                    case JobAutomation.Models.JobStatus.Sent:
                                        <span class="badge bg-success">Sent</span>
                                        break;
                                    case JobAutomation.Models.JobStatus.FollowUpSent:
                                        <span class="badge bg-primary">Follow-up Sent</span>
                                        break;
                                    case JobAutomation.Models.JobStatus.InterviewScheduled:
                                        <span class="badge bg-warning text-dark"><i class="bi bi-telephone"></i> Interview</span>
                                        break;
                                    case JobAutomation.Models.JobStatus.Offered:
                                        <span class="badge" style="background-color: var(--color-success);"><i class="bi bi-award"></i> Offered</span>
                                        break;
                                    case JobAutomation.Models.JobStatus.Rejected:
                                        <span class="badge bg-danger">Rejected</span>
                                        break;
                                    case JobAutomation.Models.JobStatus.Ghosted:
                                        <span class="badge bg-dark">Ghosted</span>
                                        break;
                                    case JobAutomation.Models.JobStatus.Skipped:
                                        <span class="badge bg-secondary">Skipped</span>
                                        break;
                                    case JobAutomation.Models.JobStatus.SavedForLater:
                                        <span class="badge bg-info text-dark">Saved</span>
                                        break;
                                    case JobAutomation.Models.JobStatus.Failed:
                                        <span class="badge bg-danger">Failed</span>
                                        break;
                                    default:
                                        <span class="badge bg-secondary">@job.Status</span>
                                        break;
                                }
                            </td>
                            <td>
                                <a href="@Url.Action("Preview", "Email", new { id = job.Id })" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-eye"></i> View
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
