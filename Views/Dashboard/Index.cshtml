@model List<JobAutomation.Models.JobPost>
@{
    ViewData["Title"] = "Dashboard";
    ViewData["Subtitle"] = "Your job application pipeline at a glance";
}

@* ── Page-level styles ── *@
<style>
    /* Stat card top-border color variants */
    .stat-card-total   { border-top: 2px solid #6366f1; }
    .stat-card-pending { border-top: 2px solid #f59e0b; }
    .stat-card-sent    { border-top: 2px solid #22c55e; }
    .stat-card-interview { border-top: 2px solid #3b82f6; }
    .stat-card-offers  { border-top: 2px solid #10b981; }
    .stat-card-response { border-top: 2px solid #a855f7; }

    /* Stat icon circle per type */
    .stat-icon-total    { background: rgba(99,102,241,0.14);  color: #818cf8; }
    .stat-icon-pending  { background: rgba(245,158,11,0.14);  color: #fbbf24; }
    .stat-icon-sent     { background: rgba(34,197,94,0.14);   color: #4ade80; }
    .stat-icon-interview{ background: rgba(59,130,246,0.14);  color: #60a5fa; }
    .stat-icon-offers   { background: rgba(16,185,129,0.14);  color: #34d399; }
    .stat-icon-response { background: rgba(168,85,247,0.14);  color: #c084fc; }

    /* Pill tabs */
    .dashboard-tabs {
        display: flex;
        gap: 6px;
        border: none;
        background: rgba(19,28,53,0.60);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-full);
        padding: 4px;
        width: fit-content;
        margin-bottom: 24px;
    }
    .dashboard-tabs .nav-link {
        border: none;
        border-radius: var(--radius-full);
        padding: 7px 20px;
        font-size: 13px;
        font-weight: 600;
        color: var(--color-text-muted);
        background: transparent;
        transition: all var(--transition-base);
        white-space: nowrap;
    }
    .dashboard-tabs .nav-link:hover {
        color: var(--color-text-secondary);
        background: rgba(255,255,255,0.05);
    }
    .dashboard-tabs .nav-link.active {
        background: var(--color-accent-gradient);
        color: #ffffff;
        box-shadow: var(--shadow-glow-sm);
    }

    /* Filter bar */
    .filter-panel {
        background: var(--color-bg-card);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        padding: 16px 20px;
        margin-bottom: 20px;
    }

    /* Table sticky header */
    .table-sticky-head thead th {
        position: sticky;
        top: 0;
        z-index: 2;
        background: #0e1628;
        box-shadow: 0 1px 0 var(--color-border);
    }

    /* Scout dot indicator */
    .scout-dot {
        display: inline-block;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
        margin-right: 5px;
    }
    .scout-dot-new       { background: #64748b; }
    .scout-dot-telegram  { background: #38bdf8; }
    .scout-dot-ignored   { background: #334155; }
    .scout-dot-applied   { background: #22c55e; }

    /* Response rate highlight */
    .stat-value-highlight {
        background: linear-gradient(135deg, #a78bfa 0%, #6366f1 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    /* Table row hover ring on company name */
    .table tbody tr:hover .company-name {
        color: var(--color-accent-light);
    }
</style>

@* ── Page header row ── *@
<div class="d-flex justify-content-between align-items-center mb-4 mt-1 gap-3 flex-wrap">
    <div>
        <h2 class="mb-0 fw-bold" style="font-size:22px; letter-spacing:-0.5px;">
            <i class="bi bi-speedometer2 me-2" style="color:var(--color-accent-light);"></i>Dashboard
        </h2>
        <p class="text-muted mb-0 mt-1" style="font-size:13px;">Monitor and manage your entire job application pipeline</p>
    </div>
    <div class="d-flex gap-2">
        <button id="btnRunScout" class="btn btn-outline-info d-inline-flex align-items-center gap-2">
            <i class="bi bi-search" id="scoutIcon"></i>
            <span id="scoutText">Search Now</span>
        </button>
        <a href="@Url.Action("Index", "Upload")" class="btn btn-glow d-inline-flex align-items-center gap-2">
            <i class="bi bi-plus-lg"></i> New Job
        </a>
    </div>
</div>

@* ── Stats Row ── *@
<div class="row g-3 mb-4">
    <div class="col-6 col-md-4 col-xl-2">
        <div class="stat-card stat-card-total h-100">
            <div class="stat-icon stat-icon-total">
                <i class="bi bi-briefcase-fill"></i>
            </div>
            <div class="stat-info mt-2">
                <div class="stat-value">@ViewBag.TotalJobs</div>
                <div class="stat-label">Total Jobs</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-xl-2">
        <div class="stat-card stat-card-pending h-100">
            <div class="stat-icon stat-icon-pending">
                <i class="bi bi-hourglass-split"></i>
            </div>
            <div class="stat-info mt-2">
                <div class="stat-value">@ViewBag.PendingJobs</div>
                <div class="stat-label">Pending Review</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-xl-2">
        <div class="stat-card stat-card-sent h-100">
            <div class="stat-icon stat-icon-sent">
                <i class="bi bi-send-check-fill"></i>
            </div>
            <div class="stat-info mt-2">
                <div class="stat-value">@ViewBag.SentJobs</div>
                <div class="stat-label">Emails Sent</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-xl-2">
        <div class="stat-card stat-card-interview h-100">
            <div class="stat-icon stat-icon-interview">
                <i class="bi bi-telephone-fill"></i>
            </div>
            <div class="stat-info mt-2">
                <div class="stat-value">@ViewBag.Interviews</div>
                <div class="stat-label">Interviews</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-xl-2">
        <div class="stat-card stat-card-offers h-100">
            <div class="stat-icon stat-icon-offers">
                <i class="bi bi-award-fill"></i>
            </div>
            <div class="stat-info mt-2">
                <div class="stat-value">@ViewBag.Offers</div>
                <div class="stat-label">Offers</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-xl-2">
        <div class="stat-card stat-card-response h-100">
            <div class="stat-icon stat-icon-response">
                <i class="bi bi-graph-up-arrow"></i>
            </div>
            <div class="stat-info mt-2">
                <div class="stat-value stat-value-highlight">@ViewBag.ResponseRate%</div>
                <div class="stat-label">Response Rate</div>
            </div>
        </div>
    </div>
</div>

@* ── Pill Tab Navigation ── *@
<ul class="nav dashboard-tabs" id="dashboardTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="applications-tab"
                data-bs-toggle="tab" data-bs-target="#applications"
                type="button" role="tab" aria-controls="applications" aria-selected="true">
            <i class="bi bi-briefcase me-2"></i>Active Applications
            @if (Model.Count > 0)
            {
                <span class="badge ms-1" style="background:rgba(255,255,255,0.18);color:#fff;font-size:10px;">@Model.Count</span>
            }
        </button>
    </li>
    <li class="nav-item" role="presentation">
        @{
            var scoutedJobsCount = (ViewBag.ScoutedJobs as List<JobAutomation.Models.ScoutedJob>)?.Count ?? 0;
        }
        <button class="nav-link" id="scout-logs-tab"
                data-bs-toggle="tab" data-bs-target="#scout-logs"
                type="button" role="tab" aria-controls="scout-logs" aria-selected="false">
            <i class="bi bi-robot me-2"></i>LinkedIn Scout Logs
            @if (scoutedJobsCount > 0)
            {
                <span class="badge ms-1" style="background:rgba(255,255,255,0.18);color:#fff;font-size:10px;">@scoutedJobsCount</span>
            }
        </button>
    </li>
</ul>

<div class="tab-content" id="dashboardTabsContent">

    @* ────────────────────────────────────────────────────────────
       TAB 1: Active Applications
       ──────────────────────────────────────────────────────────── *@
    <div class="tab-pane fade show active" id="applications" role="tabpanel" aria-labelledby="applications-tab">

        @* Filter bar *@
        <div class="filter-panel">
            <form method="get" class="row g-2 align-items-center" id="filterForm">
                <div class="col-12 col-md-5">
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-end-0">
                            <i class="bi bi-search text-muted"></i>
                        </span>
                        <input type="text" name="search" id="searchInput"
                               class="form-control border-start-0"
                               placeholder="Search company or role..."
                               value="@ViewBag.Search"
                               style="padding-left:4px!important;" />
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <select name="status" class="form-select" onchange="document.getElementById('filterForm').submit()">
                        <option value="">All Statuses</option>
                        <option value="Pending"             selected="@(ViewBag.Status == "Pending"             ? "selected" : null)">Pending</option>
                        <option value="EmailGenerated"      selected="@(ViewBag.Status == "EmailGenerated"      ? "selected" : null)">Ready for Review</option>
                        <option value="Sent"                selected="@(ViewBag.Status == "Sent"                ? "selected" : null)">Sent</option>
                        <option value="FollowUpSent"        selected="@(ViewBag.Status == "FollowUpSent"        ? "selected" : null)">Follow-up Sent</option>
                        <option value="InterviewScheduled"  selected="@(ViewBag.Status == "InterviewScheduled"  ? "selected" : null)">Interviewing</option>
                        <option value="Offered"             selected="@(ViewBag.Status == "Offered"             ? "selected" : null)">Offered</option>
                        <option value="Rejected"            selected="@(ViewBag.Status == "Rejected"            ? "selected" : null)">Rejected</option>
                    </select>
                </div>
                <div class="col-6 col-md-3">
                    <select name="sort" class="form-select" onchange="document.getElementById('filterForm').submit()">
                        <option value="">Latest First</option>
                        <option value="company" selected="@(ViewBag.Sort == "company" ? "selected" : null)">Company (A-Z)</option>
                        <option value="role"    selected="@(ViewBag.Sort == "role"    ? "selected" : null)">Role (A-Z)</option>
                        <option value="match"   selected="@(ViewBag.Sort == "match"   ? "selected" : null)">Highest Match %</option>
                    </select>
                </div>
                <div class="col-12 col-md-1 d-flex justify-content-end">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-funnel-fill"></i>
                    </button>
                </div>
            </form>
        </div>

        @* Applications table *@
        <div class="glass-panel p-0 overflow-hidden">
            @if (Model.Count == 0)
            {
                <div class="empty-state py-5">
                    <i class="bi bi-inbox empty-icon"></i>
                    <h3>No applications found</h3>
                    <p>
                        @if (!string.IsNullOrEmpty(ViewBag.Search as string) || !string.IsNullOrEmpty(ViewBag.Status as string))
                        {
                            <span>Try adjusting your filters, or</span>
                        }
                        else
                        {
                            <span>Upload a job post to get started.</span>
                        }
                    </p>
                    <a href="@Url.Action("Index", "Upload")" class="btn btn-glow">
                        <i class="bi bi-plus-lg me-2"></i>Add First Job
                    </a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0 table-sticky-head">
                        <thead>
                            <tr>
                                <th style="width:100px;">Date</th>
                                <th>Company</th>
                                <th>Role</th>
                                <th style="width:130px;">Match %</th>
                                <th style="width:140px;">Status</th>
                                <th style="width:150px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var job in Model)
                            {
                                @* compute first letter for avatar color *@
                                var firstLetter = !string.IsNullOrEmpty(job.CompanyName) ? job.CompanyName[0].ToString().ToUpper() : "J";
                                var avatarClass = firstLetter[0] switch {
                                    'A' or 'B' => "avatar-a",
                                    'C' or 'D' => "avatar-c",
                                    'E' or 'F' => "avatar-e",
                                    'G' or 'H' => "avatar-g",
                                    'I' or 'J' => "avatar-i",
                                    'K' or 'L' => "avatar-k",
                                    _          => ""
                                };
                                <tr class="job-row">
                                    <td>
                                        <span class="date-text">@job.CreatedAt.ToIst().ToString("MMM dd, yyyy")</span>
                                    </td>
                                    <td>
                                        <div class="company-cell">
                                            <div class="company-avatar @avatarClass">@firstLetter</div>
                                            <span class="company-name" title="@job.CompanyName">@job.CompanyName</span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="role-text">@job.Role</span>
                                    </td>
                                    <td>
                                        <div class="match-indicator">
                                            <div class="match-bar">
                                                <div class="match-fill @(job.SkillMatchPercentage >= 70 ? "bg-success" : job.SkillMatchPercentage >= 40 ? "bg-warning" : "bg-danger")"
                                                     style="width:@job.SkillMatchPercentage%;"
                                                     role="progressbar"
                                                     aria-valuenow="@job.SkillMatchPercentage"
                                                     aria-valuemin="0" aria-valuemax="100">
                                                </div>
                                            </div>
                                            <span class="match-text @(job.SkillMatchPercentage >= 70 ? "text-success" : job.SkillMatchPercentage >= 40 ? "text-warning" : "text-danger")"
                                                  style="font-size:12px;">
                                                @job.SkillMatchPercentage%
                                            </span>
                                        </div>
                                    </td>
                                    <td>
                                        @switch (job.Status)
                                        {
                                            case JobAutomation.Models.JobStatus.Pending:
                                                <span class="badge bg-secondary"><i class="bi bi-hourglass me-1"></i>Processing</span>
                                                break;
                                            case JobAutomation.Models.JobStatus.EmailGenerated:
                                                <span class="badge bg-info text-dark"><i class="bi bi-envelope-check me-1"></i>Ready</span>
                                                break;
                                            case JobAutomation.Models.JobStatus.Approved:
                                                <span class="badge bg-primary"><i class="bi bi-check me-1"></i>Approved</span>
                                                break;
                                            case JobAutomation.Models.JobStatus.Sent:
                                                <span class="badge bg-success"><i class="bi bi-send-check me-1"></i>Sent</span>
                                                break;
                                            case JobAutomation.Models.JobStatus.FollowUpSent:
                                                <span class="badge bg-primary"><i class="bi bi-arrow-clockwise me-1"></i>Follow-up</span>
                                                break;
                                            case JobAutomation.Models.JobStatus.InterviewScheduled:
                                                <span class="badge bg-warning text-dark"><i class="bi bi-telephone me-1"></i>Interview</span>
                                                break;
                                            case JobAutomation.Models.JobStatus.Offered:
                                                <span class="badge bg-success"><i class="bi bi-award me-1"></i>Offered</span>
                                                break;
                                            case JobAutomation.Models.JobStatus.Rejected:
                                                <span class="badge bg-danger"><i class="bi bi-x-circle me-1"></i>Rejected</span>
                                                break;
                                            case JobAutomation.Models.JobStatus.Ghosted:
                                                <span class="badge bg-dark"><i class="bi bi-question-circle me-1"></i>Ghosted</span>
                                                break;
                                            case JobAutomation.Models.JobStatus.Skipped:
                                                <span class="badge bg-secondary">Skipped</span>
                                                break;
                                            case JobAutomation.Models.JobStatus.SavedForLater:
                                                <span class="badge bg-info text-dark"><i class="bi bi-bookmark me-1"></i>Saved</span>
                                                break;
                                            case JobAutomation.Models.JobStatus.Failed:
                                                <span class="badge bg-danger"><i class="bi bi-exclamation-triangle me-1"></i>Failed</span>
                                                break;
                                            default:
                                                <span class="badge bg-secondary">@job.Status</span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center gap-1">
                                            <a href="@Url.Action("Preview", "Email", new { id = job.Id })"
                                               class="btn btn-sm btn-outline-primary"
                                               title="View email preview">
                                                <i class="bi bi-eye me-1"></i>View
                                            </a>
                                            @if (job.GeneratedEmail?.OpenedAt.HasValue == true)
                                            {
                                                <span class="btn btn-sm btn-outline-success disabled"
                                                      title="Email opened @job.GeneratedEmail.OpenedAt.ToIstString("MMM dd, HH:mm", true)">
                                                    <i class="bi bi-eye-fill"></i>
                                                </span>
                                            }
                                            @if (job.GeneratedEmail?.RepliedAt.HasValue == true)
                                            {
                                                var replyIcon = job.GeneratedEmail.ReplyClassification switch {
                                                    "interview"  => "bi-telephone-fill text-info",
                                                    "rejected"   => "bi-x-circle-fill text-danger",
                                                    "interested" => "bi-star-fill text-warning",
                                                    _            => "bi-envelope-open-fill text-secondary"
                                                };
                                                <span class="btn btn-sm btn-outline-secondary disabled"
                                                      title="Reply: @job.GeneratedEmail.ReplyClassification">
                                                    <i class="bi @replyIcon"></i>
                                                </span>
                                            }
                                            @* Temporarily disabled Co-Pilot
                                            <a href="@Url.Action("CoPilot", "Interview", new { id = job.Id })" class="btn btn-sm btn-outline-danger" target="_blank">
                                                <i class="bi bi-mic-fill"></i> Co-Pilot
                                            </a>
                                            *@
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    @* ────────────────────────────────────────────────────────────
       TAB 2: LinkedIn Scout Logs
       ──────────────────────────────────────────────────────────── *@
    <div class="tab-pane fade" id="scout-logs" role="tabpanel" aria-labelledby="scout-logs-tab">
        @{
            var scoutedJobs = ViewBag.ScoutedJobs as List<JobAutomation.Models.ScoutedJob> ?? new List<JobAutomation.Models.ScoutedJob>();
        }
        <div class="glass-panel p-0 overflow-hidden">
            @if (scoutedJobs.Count == 0)
            {
                <div class="empty-state py-5">
                    <i class="bi bi-robot empty-icon"></i>
                    <h3>No scout logs yet</h3>
                    <p>The background LinkedIn scout hasn't run yet, or no matches were found for your keywords.</p>
                    <button id="btnRunScout2" class="btn btn-outline-info d-inline-flex align-items-center gap-2">
                        <i class="bi bi-search"></i> Run Scout Now
                    </button>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0 table-sticky-head">
                        <thead>
                            <tr>
                                <th style="width:120px;">Date</th>
                                <th style="width:130px;">Keyword</th>
                                <th style="width:160px;">Status</th>
                                <th>Text Preview</th>
                                <th class="text-end pe-4" style="width:190px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var sJob in scoutedJobs)
                            {
                                <tr>
                                    <td class="align-middle">
                                        <span class="date-text">@sJob.CreatedAt.ToIst().ToString("MMM dd, HH:mm")</span>
                                    </td>
                                    <td class="align-middle">
                                        <span class="badge bg-secondary">@sJob.KeywordMatched</span>
                                    </td>
                                    <td class="align-middle">
                                        @switch (sJob.Status)
                                        {
                                            case JobAutomation.Models.ScoutedJobStatus.New:
                                                <span class="d-inline-flex align-items-center gap-1">
                                                    <span class="scout-dot scout-dot-new"></span>
                                                    <span class="badge bg-secondary">New</span>
                                                </span>
                                                break;
                                            case JobAutomation.Models.ScoutedJobStatus.SentToTelegram:
                                                <span class="d-inline-flex align-items-center gap-1">
                                                    <span class="scout-dot scout-dot-telegram"></span>
                                                    <span class="badge bg-info text-dark"><i class="bi bi-telegram me-1"></i>Sent to Telegram</span>
                                                </span>
                                                break;
                                            case JobAutomation.Models.ScoutedJobStatus.IgnoredByGemini:
                                                <span class="d-inline-flex align-items-center gap-1">
                                                    <span class="scout-dot scout-dot-ignored"></span>
                                                    <span class="badge bg-dark text-muted"><i class="bi bi-x-circle me-1"></i>Ignored by AI</span>
                                                </span>
                                                break;
                                            case JobAutomation.Models.ScoutedJobStatus.Applied:
                                                <span class="d-inline-flex align-items-center gap-1">
                                                    <span class="scout-dot scout-dot-applied"></span>
                                                    <span class="badge bg-success"><i class="bi bi-check-circle-fill me-1"></i>Applied</span>
                                                </span>
                                                break;
                                            default:
                                                <span class="badge bg-secondary">@sJob.Status</span>
                                                break;
                                        }
                                    </td>
                                    <td class="align-middle">
                                        <span class="role-text text-truncate d-inline-block"
                                              style="max-width:420px;"
                                              title="@sJob.RawText">
                                            @(sJob.RawText != null && sJob.RawText.Length > 90
                                                ? sJob.RawText.Substring(0, 90) + "…"
                                                : sJob.RawText)
                                        </span>
                                    </td>
                                    <td class="align-middle text-end pe-4">
                                        <div class="d-flex justify-content-end gap-2">
                                            <a href="@sJob.LinkedInUrl" target="_blank"
                                               class="btn btn-sm btn-outline-info"
                                               title="Open LinkedIn post">
                                                <i class="bi bi-box-arrow-up-right me-1"></i>Post
                                            </a>
                                            @if (sJob.Status == JobAutomation.Models.ScoutedJobStatus.New ||
                                                 sJob.Status == JobAutomation.Models.ScoutedJobStatus.SentToTelegram)
                                            {
                                                <button type="button"
                                                        class="btn btn-sm btn-glow btn-web-apply"
                                                        data-job-id="@sJob.Id"
                                                        title="Apply via AutoMail">
                                                    <i class="bi bi-send-fill me-1"></i>Apply
                                                </button>
                                            }
                                            else if (sJob.Status == JobAutomation.Models.ScoutedJobStatus.Applied)
                                            {
                                                <button type="button" class="btn btn-sm btn-outline-success" disabled>
                                                    <i class="bi bi-check-circle-fill me-1"></i>Applied
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

</div>

@section Scripts {
    <script>
        // ── Web-apply handler for scouted jobs ──────────────────────
        document.querySelectorAll('.btn-web-apply').forEach(btn => {
            btn.addEventListener('click', async function () {
                const jobId = this.dataset.jobId;
                const originalHtml = this.innerHTML;
                this.disabled = true;
                this.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Starting...';

                try {
                    const response = await fetch(`@Url.Action("ApplyScoutedJob", "Dashboard")?id=${jobId}`, {
                        method: 'POST'
                    });

                    const result = await response.json();
                    if (result.success) {
                        window.location.href = result.redirectUrl;
                    } else {
                        alert('Failed to start: ' + (result.message || 'Unknown error'));
                        this.disabled = false;
                        this.innerHTML = originalHtml;
                    }
                } catch (err) {
                    console.error(err);
                    alert('Request failed. Check console for details.');
                    this.disabled = false;
                    this.innerHTML = originalHtml;
                }
            });
        });

        // ── Run Scout Now handler (header button) ────────────────────
        function attachScoutHandler(btnId) {
            const btn = document.getElementById(btnId);
            if (!btn) return;
            btn.addEventListener('click', async function () {
                const icon = this.querySelector('i') || document.getElementById('scoutIcon');
                const textEl = this.querySelector('span') || document.getElementById('scoutText');
                const origIcon = icon ? icon.className : '';
                const origText = textEl ? textEl.textContent : '';

                this.disabled = true;
                if (icon) icon.className = 'spinner-border spinner-border-sm';
                if (textEl) textEl.textContent = 'Scouting...';

                try {
                    const response = await fetch('@Url.Action("RunScoutNow", "Dashboard")', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' }
                    });

                    if (response.ok) {
                        this.classList.remove('btn-outline-info');
                        this.classList.add('btn-success');
                        if (icon) icon.className = 'bi bi-check-circle';
                        if (textEl) textEl.textContent = 'Scout Complete!';

                        setTimeout(() => {
                            this.classList.remove('btn-success');
                            this.classList.add('btn-outline-info');
                            this.disabled = false;
                            if (icon) icon.className = origIcon;
                            if (textEl) textEl.textContent = origText;
                        }, 3000);
                    } else {
                        throw new Error('Scout request failed');
                    }
                } catch (error) {
                    console.error(error);
                    this.classList.remove('btn-outline-info');
                    this.classList.add('btn-danger');
                    if (icon) icon.className = 'bi bi-exclamation-triangle';
                    if (textEl) textEl.textContent = 'Scout Failed';

                    setTimeout(() => {
                        this.classList.remove('btn-danger');
                        this.classList.add('btn-outline-info');
                        this.disabled = false;
                        if (icon) icon.className = origIcon;
                        if (textEl) textEl.textContent = origText;
                    }, 3000);
                }
            });
        }

        attachScoutHandler('btnRunScout');
        attachScoutHandler('btnRunScout2'); // empty-state button in scout tab
    </script>
}
