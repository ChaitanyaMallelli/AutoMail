<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - JobFlow AI</title>
    <meta name="description" content="AI-powered job application automation tool" />

    <!-- Google Font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        /* ── Sidebar gradient ── */
        .sidebar {
            background: linear-gradient(180deg, #06091a 0%, #080d1c 60%, #06091a 100%);
        }

        /* ── Brand refinements ── */
        .sidebar-brand {
            text-decoration: none;
        }
        .brand-icon {
            width: 38px;
            height: 38px;
            min-width: 38px;
            border-radius: 10px;
            background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 17px;
            color: #fff;
            box-shadow: 0 0 14px rgba(99, 102, 241, 0.40);
            flex-shrink: 0;
        }
        .brand-name {
            font-size: 19px;
            font-weight: 700;
            color: #e2e8f0;
            letter-spacing: -0.5px;
        }
        .brand-badge {
            font-size: 10px;
            font-weight: 700;
            padding: 2px 7px;
            border-radius: 9999px;
            background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
            color: #fff;
            letter-spacing: 0.6px;
            line-height: 1.6;
        }

        /* ── Nav section label ── */
        .nav-section-title {
            font-size: 10px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1.8px;
            color: #4a5568;
            padding: 0 10px;
            margin-bottom: 4px;
            margin-top: 2px;
            display: block;
        }

        /* ── Nav link ── */
        .sidebar-nav .nav-link {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 9px 10px;
            border-radius: 8px;
            color: #7a8ba0;
            font-size: 13.5px;
            font-weight: 500;
            text-decoration: none;
            transition: all 0.18s ease;
            margin-bottom: 1px;
            border-left: 2px solid transparent;
            position: relative;
        }
        .sidebar-nav .nav-link i {
            font-size: 16px;
            width: 20px;
            text-align: center;
            flex-shrink: 0;
            transition: color 0.18s ease;
        }
        .sidebar-nav .nav-link:hover {
            background: rgba(99, 102, 241, 0.08);
            color: #c7d2fe;
            border-left-color: rgba(99, 102, 241, 0.35);
        }
        .sidebar-nav .nav-link:hover i {
            color: #818cf8;
        }
        .sidebar-nav .nav-link.active {
            background: rgba(99, 102, 241, 0.14);
            color: #a5b4fc;
            border-left-color: #6366f1;
            font-weight: 600;
        }
        .sidebar-nav .nav-link.active i {
            color: #818cf8;
        }

        /* ── Logout link ── */
        .sidebar-nav .nav-link.nav-logout {
            color: #ef4444;
            margin-top: 8px;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            padding-top: 12px;
            border-radius: 0 0 8px 8px;
            border-left: 2px solid transparent;
        }
        .sidebar-nav .nav-link.nav-logout i {
            color: #ef4444;
        }
        .sidebar-nav .nav-link.nav-logout:hover {
            background: rgba(239, 68, 68, 0.08);
            color: #f87171;
            border-left-color: rgba(239, 68, 68, 0.45);
        }
        .sidebar-nav .nav-link.nav-logout:hover i {
            color: #f87171;
        }

        /* ── Sidebar footer ── */
        .sidebar-footer {
            padding: 12px 20px;
            border-top: 1px solid rgba(148, 163, 184, 0.07);
            flex-shrink: 0;
        }
        .sidebar-footer-content {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 11px;
            color: #4a5568;
        }
        .sidebar-footer-content i {
            font-size: 14px;
            color: #6366f1;
            opacity: 0.65;
        }

        /* ── Mobile toggle ── */
        .sidebar-toggle {
            position: fixed;
            top: 14px;
            left: 14px;
            z-index: 1100;
            width: 40px;
            height: 40px;
            border: 1px solid rgba(148, 163, 184, 0.12);
            border-radius: 9px;
            background: rgba(19, 28, 53, 0.92);
            color: #e2e8f0;
            font-size: 18px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.40);
            transition: all 0.18s ease;
            backdrop-filter: blur(8px);
        }
        .sidebar-toggle:hover {
            background: rgba(99, 102, 241, 0.18);
            border-color: rgba(99, 102, 241, 0.45);
            color: #a5b4fc;
        }

        /* ── Header badge ── */
        .header-app-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 4px 11px;
            border-radius: 9999px;
            background: rgba(99, 102, 241, 0.10);
            border: 1px solid rgba(99, 102, 241, 0.22);
            font-size: 11px;
            font-weight: 600;
            color: #818cf8;
            letter-spacing: 0.4px;
        }
        .header-app-badge i {
            font-size: 12px;
        }

        /* ── Header time ── */
        .header-time {
            font-size: 13px;
            color: #64748b;
            display: flex;
            align-items: center;
            gap: 6px;
            font-variant-numeric: tabular-nums;
            letter-spacing: 0.1px;
        }
        .header-time i {
            font-size: 13px;
            color: #6366f1;
            opacity: 0.75;
        }

        /* ── Alerts ── */
        .layout-alert {
            margin: 12px 32px 0;
            border-radius: 10px;
            font-size: 13.5px;
            font-weight: 500;
        }
        .layout-alert.alert-success {
            background: rgba(34, 197, 94, 0.10);
            border: 1px solid rgba(34, 197, 94, 0.25);
            color: #4ade80;
        }
        .layout-alert.alert-danger {
            background: rgba(239, 68, 68, 0.10);
            border: 1px solid rgba(239, 68, 68, 0.25);
            color: #f87171;
        }
        .layout-alert .btn-close {
            filter: brightness(0) invert(1);
            opacity: 0.35;
        }
        .layout-alert .btn-close:hover {
            opacity: 0.65;
        }

        /* ── Header separator ── */
        .content-header {
            border-bottom: 1px solid rgba(148, 163, 184, 0.09);
            background: rgba(8, 13, 28, 0.78);
        }

        /* ── Sidebar slide-in animation ── */
        @@media (max-width: 991.98px) {
            .sidebar {
                transform: translateX(-100%);
                transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
                box-shadow: 4px 0 32px rgba(0, 0, 0, 0.55);
            }
            .sidebar.show {
                transform: translateX(0);
            }
            .sidebar-overlay {
                display: block;
            }
        }
    </style>
</head>
<body>
    <div class="app-container">

        <!-- Sidebar backdrop (mobile) -->
        <div class="sidebar-overlay" id="sidebarOverlay"></div>

        <!-- Sidebar -->
        <aside class="sidebar" id="sidebar">

            <!-- Brand -->
            <div class="sidebar-header">
                <a href="@Url.Action("Index", "Dashboard")" class="sidebar-brand" style="text-decoration:none;">
                    <div class="brand-icon">
                        <i class="bi bi-briefcase-fill"></i>
                    </div>
                    <div class="brand-text">
                        <span class="brand-name">JobFlow</span>
                        <span class="brand-badge">AI</span>
                    </div>
                </a>
            </div>

            <!-- Navigation -->
            <nav class="sidebar-nav">

                <!-- Main -->
                <div class="nav-section">
                    <span class="nav-section-title">Main</span>
                    <a href="@Url.Action("Index", "Dashboard")"
                       class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                        <i class="bi bi-grid-1x2-fill"></i>
                        <span>Dashboard</span>
                    </a>
                    <a href="@Url.Action("Index", "Upload")"
                       class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Upload" ? "active" : "")">
                        <i class="bi bi-cloud-arrow-up-fill"></i>
                        <span>New Job</span>
                    </a>
                </div>

                <!-- Emails -->
                <div class="nav-section">
                    <span class="nav-section-title">Emails</span>
                    <a href="@Url.Action("History", "Email")"
                       class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Email" && ViewContext.RouteData.Values["action"]?.ToString() == "History" ? "active" : "")">
                        <i class="bi bi-envelope-fill"></i>
                        <span>Email History</span>
                    </a>
                    <a href="@Url.Action("Export", "Email")"
                       class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Email" && ViewContext.RouteData.Values["action"]?.ToString() == "Export" ? "active" : "")">
                        <i class="bi bi-file-earmark-spreadsheet-fill"></i>
                        <span>Export CSV</span>
                    </a>
                </div>

                <!-- Settings -->
                <div class="nav-section">
                    <span class="nav-section-title">Settings</span>
                    <a href="@Url.Action("Index", "Resume")"
                       class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Resume" ? "active" : "")">
                        <i class="bi bi-file-earmark-person-fill"></i>
                        <span>Resume &amp; Profile</span>
                    </a>
                    <a href="@Url.Action("Index", "Telegram")"
                       class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Telegram" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                        <i class="bi bi-telegram"></i>
                        <span>Telegram Bot</span>
                    </a>
                    <a href="@Url.Action("Progress", "Telegram")"
                       class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Telegram" && ViewContext.RouteData.Values["action"]?.ToString() == "Progress" ? "active" : "")">
                        <i class="bi bi-activity"></i>
                        <span>Live Activity</span>
                    </a>
                </div>

                <!-- Scout Sidebar ViewComponent -->
                @await Component.InvokeAsync("ScoutSidebar")

                <!-- Logout -->
                <div class="nav-section" style="margin-top:auto;">
                    <a href="@Url.Action("Logout", "Login")" class="nav-link nav-logout">
                        <i class="bi bi-box-arrow-right"></i>
                        <span>Logout</span>
                    </a>
                </div>

            </nav>

            <!-- Footer -->
            <div class="sidebar-footer">
                <div class="sidebar-footer-content">
                    <i class="bi bi-robot"></i>
                    <span>Powered by Gemini AI</span>
                </div>
            </div>

        </aside>

        <!-- Mobile hamburger toggle -->
        <button class="sidebar-toggle d-lg-none" id="sidebarToggle" aria-label="Toggle sidebar">
            <i class="bi bi-list"></i>
        </button>

        <!-- Main content -->
        <main class="main-content">

            <!-- Sticky header -->
            <header class="content-header">
                <div class="header-left">
                    <h1 class="page-title">@ViewData["Title"]</h1>
                    @if (ViewData["Subtitle"] != null)
                    {
                        <p class="page-subtitle">@ViewData["Subtitle"]</p>
                    }
                </div>
                <div class="header-right">
                    <div class="header-time">
                        <i class="bi bi-clock"></i>
                        <span id="currentTime"></span>
                    </div>
                    <div class="header-app-badge">
                        <i class="bi bi-lightning-charge-fill"></i>
                        JobFlow AI
                    </div>
                </div>
            </header>

            <!-- Flash alerts (inside content, below header) -->
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-dismissible fade show layout-alert alert-success" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    @TempData["Success"]
                    <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-dismissible fade show layout-alert alert-danger" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    @TempData["Error"]
                    <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <!-- Page body -->
            <div class="content-body">
                @RenderBody()
            </div>

        </main>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        // ── Live clock ──────────────────────────────────────────────
        function updateClock() {
            var el = document.getElementById('currentTime');
            if (!el) return;
            var now = new Date();
            var h = now.getHours().toString().padStart(2, '0');
            var m = now.getMinutes().toString().padStart(2, '0');
            var s = now.getSeconds().toString().padStart(2, '0');
            el.textContent = h + ':' + m + ':' + s;
        }
        updateClock();
        setInterval(updateClock, 1000);

        // ── Sidebar toggle (mobile) ─────────────────────────────────
        var sidebar  = document.getElementById('sidebar');
        var overlay  = document.getElementById('sidebarOverlay');
        var toggle   = document.getElementById('sidebarToggle');

        function openSidebar() {
            if (!sidebar) return;
            sidebar.classList.add('show');
            if (overlay) {
                overlay.style.display = 'block';
                requestAnimationFrame(function () {
                    overlay.classList.add('active');
                });
            }
        }

        function closeSidebar() {
            if (!sidebar) return;
            sidebar.classList.remove('show');
            if (overlay) {
                overlay.classList.remove('active');
                setTimeout(function () { overlay.style.display = 'none'; }, 350);
            }
        }

        if (toggle) {
            toggle.addEventListener('click', function () {
                if (sidebar && sidebar.classList.contains('show')) {
                    closeSidebar();
                } else {
                    openSidebar();
                }
            });
        }

        // Backdrop click closes sidebar
        if (overlay) {
            overlay.addEventListener('click', closeSidebar);
        }

        // Close sidebar on resize to desktop
        window.addEventListener('resize', function () {
            if (window.innerWidth >= 992) {
                closeSidebar();
            }
        });

        // ── Active nav link detection ───────────────────────────────
        (function () {
            var path = window.location.pathname.toLowerCase();
            var links = document.querySelectorAll('.sidebar-nav .nav-link');
            var bestMatch = null;
            var bestLen   = 0;

            links.forEach(function (link) {
                if (link.classList.contains('nav-logout')) return;
                var href = (link.getAttribute('href') || '').toLowerCase();
                if (href && href !== '#' && path.startsWith(href) && href.length > bestLen) {
                    bestLen   = href.length;
                    bestMatch = link;
                }
            });

            // Remove server-rendered active classes first
            links.forEach(function (link) { link.classList.remove('active'); });

            if (bestMatch) {
                bestMatch.classList.add('active');
            }
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
