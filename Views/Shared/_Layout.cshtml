<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - JobFlow AI</title>
    <meta name="description" content="AI-powered job application automation tool" />

    <!-- Google Font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        /* ================================================================
           DESIGN TOKENS
        ================================================================ */
        :root {
            --bg-base:          #09090b;
            --bg-elevated:      #111118;
            --bg-card:          #16161f;
            --border:           rgba(255,255,255,0.07);
            --border-hover:     rgba(124,58,237,0.35);
            --accent-violet:    #7c3aed;
            --accent-indigo:    #6366f1;
            --accent-pink:      #ec4899;
            --grad-primary:     linear-gradient(135deg, #7c3aed 0%, #6366f1 100%);
            --grad-hot:         linear-gradient(135deg, #ec4899 0%, #7c3aed 100%);
            --glow-violet:      0 0 20px rgba(124,58,237,0.35);
            --glow-sm:          0 0 12px rgba(124,58,237,0.2);
            --text-primary:     #f4f4f5;
            --text-secondary:   #a1a1aa;
            --text-muted:       #52525b;
            --success:          #22c55e;
            --success-bg:       rgba(34,197,94,0.12);
            --warning:          #f59e0b;
            --warning-bg:       rgba(245,158,11,0.12);
            --danger:           #ef4444;
            --danger-bg:        rgba(239,68,68,0.12);
            --info:             #3b82f6;
            --info-bg:          rgba(59,130,246,0.12);
            --radius-sm:        6px;
            --radius-md:        10px;
            --radius-lg:        14px;
            --radius-xl:        20px;
            --sidebar-w:        248px;
            --header-h:         64px;
        }

        /* ================================================================
           RESET / BASE
        ================================================================ */
        *, *::before, *::after { box-sizing: border-box; }

        html, body {
            height: 100%;
            margin: 0;
            padding: 0;
            font-family: Inter, -apple-system, sans-serif;
            background: var(--bg-base);
            color: var(--text-primary);
            -webkit-font-smoothing: antialiased;
        }

        /* ================================================================
           APP SHELL
        ================================================================ */
        .app-container {
            display: flex;
            min-height: 100vh;
            background: var(--bg-base);
        }

        /* ================================================================
           SIDEBAR
        ================================================================ */
        .sidebar {
            width: var(--sidebar-w);
            min-width: var(--sidebar-w);
            height: 100vh;
            position: sticky;
            top: 0;
            display: flex;
            flex-direction: column;
            background: var(--bg-elevated);
            border-right: 1px solid var(--border);
            overflow-y: auto;
            overflow-x: hidden;
            z-index: 900;
            scrollbar-width: none;
        }
        .sidebar::-webkit-scrollbar { display: none; }

        /* ── Brand ── */
        .sidebar-header {
            padding: 20px 16px 16px;
            flex-shrink: 0;
            border-bottom: 1px solid var(--border);
        }
        .sidebar-brand {
            display: flex;
            align-items: center;
            gap: 11px;
            text-decoration: none;
        }
        .brand-icon {
            width: 40px;
            height: 40px;
            min-width: 40px;
            border-radius: 50%;
            background: var(--grad-primary);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            color: #fff;
            box-shadow: var(--glow-sm);
            flex-shrink: 0;
        }
        .brand-text {
            display: flex;
            align-items: center;
            gap: 7px;
        }
        .brand-name {
            font-size: 19px;
            font-weight: 700;
            color: var(--text-primary);
            letter-spacing: -0.4px;
            line-height: 1;
        }
        .brand-badge {
            font-size: 10px;
            font-weight: 700;
            padding: 2px 8px;
            border-radius: 9999px;
            background: var(--grad-hot);
            color: #fff;
            letter-spacing: 0.5px;
            line-height: 1.7;
            flex-shrink: 0;
        }

        /* ── Navigation ── */
        .sidebar-nav {
            flex: 1;
            padding: 12px 10px;
            display: flex;
            flex-direction: column;
            gap: 0;
        }
        .nav-section {
            margin-bottom: 6px;
        }
        .nav-section-title {
            display: block;
            font-size: 10px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1.8px;
            color: var(--text-muted);
            padding: 8px 10px 4px;
        }
        .sidebar-nav .nav-link {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 9px 10px;
            border-radius: var(--radius-md);
            color: var(--text-secondary);
            font-size: 13.5px;
            font-weight: 500;
            text-decoration: none;
            transition: background 0.18s ease, color 0.18s ease, border-left-color 0.18s ease;
            margin-bottom: 1px;
            border-left: 2px solid transparent;
            position: relative;
        }
        .sidebar-nav .nav-link i {
            font-size: 16px;
            width: 20px;
            text-align: center;
            flex-shrink: 0;
            transition: color 0.18s ease;
        }
        .sidebar-nav .nav-link:hover {
            background: rgba(124,58,237,0.08);
            color: #c4b5fd;
            border-left-color: rgba(124,58,237,0.4);
        }
        .sidebar-nav .nav-link:hover i {
            color: #a78bfa;
        }
        .sidebar-nav .nav-link.active {
            background: rgba(124,58,237,0.14);
            color: #a78bfa;
            border-left-color: var(--accent-violet);
            font-weight: 600;
        }
        .sidebar-nav .nav-link.active i {
            color: #a78bfa;
        }

        /* ── Logout ── */
        .nav-logout-section {
            margin-top: auto;
            padding-top: 8px;
            border-top: 1px solid var(--border);
        }
        .sidebar-nav .nav-link.nav-logout {
            color: var(--danger);
            border-left: 2px solid transparent;
        }
        .sidebar-nav .nav-link.nav-logout i {
            color: var(--danger);
        }
        .sidebar-nav .nav-link.nav-logout:hover {
            background: var(--danger-bg);
            color: #f87171;
            border-left-color: rgba(239,68,68,0.5);
        }
        .sidebar-nav .nav-link.nav-logout:hover i {
            color: #f87171;
        }

        /* ── Sidebar footer ── */
        .sidebar-footer {
            padding: 12px 16px;
            border-top: 1px solid var(--border);
            flex-shrink: 0;
        }
        .sidebar-footer-content {
            display: flex;
            align-items: center;
            gap: 7px;
            font-size: 11px;
            color: var(--text-muted);
        }
        .sidebar-footer-content i {
            font-size: 14px;
            color: var(--accent-violet);
            opacity: 0.6;
        }

        /* ================================================================
           MOBILE TOGGLE
        ================================================================ */
        .sidebar-toggle {
            position: fixed;
            top: 14px;
            left: 14px;
            z-index: 1100;
            width: 40px;
            height: 40px;
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            background: rgba(17,17,24,0.92);
            color: var(--text-primary);
            font-size: 18px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 16px rgba(0,0,0,0.5);
            transition: background 0.18s ease, border-color 0.18s ease, color 0.18s ease;
            backdrop-filter: blur(10px);
        }
        .sidebar-toggle:hover {
            background: rgba(124,58,237,0.18);
            border-color: var(--border-hover);
            color: #c4b5fd;
        }

        /* ── Backdrop ── */
        .sidebar-backdrop {
            display: none;
            position: fixed;
            inset: 0;
            z-index: 850;
            background: rgba(0,0,0,0.6);
            backdrop-filter: blur(3px);
            opacity: 0;
            transition: opacity 0.3s ease;
        }
        .sidebar-backdrop.active {
            opacity: 1;
        }

        /* ================================================================
           MAIN CONTENT
        ================================================================ */
        .main-content {
            flex: 1;
            min-width: 0;
            display: flex;
            flex-direction: column;
            background: var(--bg-base);
        }

        /* ── Content header ── */
        .content-header {
            height: var(--header-h);
            min-height: var(--header-h);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 28px;
            border-bottom: 1px solid var(--border);
            background: rgba(9,9,11,0.85);
            backdrop-filter: blur(12px);
            position: sticky;
            top: 0;
            z-index: 500;
            flex-shrink: 0;
        }
        .header-left {
            display: flex;
            flex-direction: column;
            justify-content: center;
            gap: 1px;
            overflow: hidden;
        }
        .page-title {
            font-size: 18px;
            font-weight: 700;
            color: var(--text-primary);
            margin: 0;
            line-height: 1.25;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            letter-spacing: -0.3px;
        }
        .page-subtitle {
            font-size: 12.5px;
            color: var(--text-muted);
            margin: 0;
            line-height: 1.3;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .header-right {
            display: flex;
            align-items: center;
            gap: 14px;
            flex-shrink: 0;
        }
        .header-time {
            font-size: 13px;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 6px;
            font-variant-numeric: tabular-nums;
            letter-spacing: 0.3px;
        }
        .header-time i {
            font-size: 13px;
            color: var(--accent-violet);
            opacity: 0.7;
        }
        .header-app-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 4px 12px;
            border-radius: 9999px;
            background: rgba(124,58,237,0.10);
            border: 1px solid rgba(124,58,237,0.22);
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.4px;
            background-clip: padding-box;
        }
        .header-app-badge span {
            background: var(--grad-primary);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .header-app-badge i {
            font-size: 12px;
            color: var(--accent-violet);
        }

        /* ================================================================
           ALERTS
        ================================================================ */
        .layout-alert {
            margin: 14px 28px 0;
            border-radius: var(--radius-md);
            font-size: 13.5px;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .layout-alert.alert-success {
            background: var(--success-bg);
            border: 1px solid rgba(34,197,94,0.28);
            color: var(--success);
        }
        .layout-alert.alert-danger {
            background: var(--danger-bg);
            border: 1px solid rgba(239,68,68,0.28);
            color: var(--danger);
        }
        .layout-alert .btn-close {
            filter: brightness(0) invert(1);
            opacity: 0.35;
            margin-left: auto;
        }
        .layout-alert .btn-close:hover {
            opacity: 0.7;
        }

        /* ================================================================
           CONTENT BODY
        ================================================================ */
        .content-body {
            flex: 1;
            padding: 28px;
            overflow-y: auto;
        }

        /* ================================================================
           MOBILE RESPONSIVE
        ================================================================ */
        @@media (max-width: 991.98px) {
            .sidebar {
                position: fixed;
                left: 0;
                top: 0;
                height: 100vh;
                transform: translateX(-100%);
                transition: transform 0.32s cubic-bezier(0.4, 0, 0.2, 1);
                box-shadow: 6px 0 40px rgba(0,0,0,0.6);
                z-index: 960;
            }
            .sidebar.show {
                transform: translateX(0);
            }
            .sidebar-backdrop {
                display: block;
            }
            .sidebar-toggle {
                display: flex !important;
            }
            .content-header {
                padding: 0 16px 0 62px;
            }
            .content-body {
                padding: 16px;
            }
            .layout-alert {
                margin: 12px 16px 0;
            }
        }
        @@media (min-width: 992px) {
            .sidebar-toggle {
                display: none !important;
            }
        }
    </style>
</head>
<body>
    <div class="app-container">

        <!-- Mobile backdrop -->
        <div class="sidebar-backdrop" id="sidebarBackdrop"></div>

        <!-- Sidebar -->
        <aside class="sidebar" id="sidebar">

            <!-- Brand -->
            <div class="sidebar-header">
                <a href="@Url.Action("Index", "Dashboard")" class="sidebar-brand">
                    <div class="brand-icon">
                        <i class="bi bi-briefcase-fill"></i>
                    </div>
                    <div class="brand-text">
                        <span class="brand-name">JobFlow</span>
                        <span class="brand-badge">AI</span>
                    </div>
                </a>
            </div>

            <!-- Navigation -->
            <nav class="sidebar-nav">

                <!-- Main -->
                <div class="nav-section">
                    <span class="nav-section-title">Main</span>
                    <a href="@Url.Action("Index", "Dashboard")"
                       class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                        <i class="bi bi-grid-1x2-fill"></i>
                        <span>Dashboard</span>
                    </a>
                    <a href="@Url.Action("Index", "Upload")"
                       class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Upload" ? "active" : "")">
                        <i class="bi bi-cloud-arrow-up-fill"></i>
                        <span>New Job</span>
                    </a>
                </div>

                <!-- Emails -->
                <div class="nav-section">
                    <span class="nav-section-title">Emails</span>
                    <a href="@Url.Action("History", "Email")"
                       class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Email" && ViewContext.RouteData.Values["action"]?.ToString() == "History" ? "active" : "")">
                        <i class="bi bi-envelope-fill"></i>
                        <span>Email History</span>
                    </a>
                    <a href="@Url.Action("Export", "Email")"
                       class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Email" && ViewContext.RouteData.Values["action"]?.ToString() == "Export" ? "active" : "")">
                        <i class="bi bi-file-earmark-spreadsheet-fill"></i>
                        <span>Export CSV</span>
                    </a>
                </div>

                <!-- Settings -->
                <div class="nav-section">
                    <span class="nav-section-title">Settings</span>
                    <a href="@Url.Action("Index", "Resume")"
                       class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Resume" ? "active" : "")">
                        <i class="bi bi-file-earmark-person-fill"></i>
                        <span>Resume &amp; Profile</span>
                    </a>
                    <a href="@Url.Action("Index", "Telegram")"
                       class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Telegram" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                        <i class="bi bi-telegram"></i>
                        <span>Telegram Bot</span>
                    </a>
                    <a href="@Url.Action("Progress", "Telegram")"
                       class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Telegram" && ViewContext.RouteData.Values["action"]?.ToString() == "Progress" ? "active" : "")">
                        <i class="bi bi-activity"></i>
                        <span>Live Activity</span>
                    </a>
                </div>

                <!-- Scout Sidebar ViewComponent -->
                @await Component.InvokeAsync("ScoutSidebar")

                <!-- Logout -->
                <div class="nav-logout-section">
                    <a href="@Url.Action("Logout", "Login")" class="nav-link nav-logout">
                        <i class="bi bi-box-arrow-right"></i>
                        <span>Logout</span>
                    </a>
                </div>

            </nav>

            <!-- Footer -->
            <div class="sidebar-footer">
                <div class="sidebar-footer-content">
                    <i class="bi bi-robot"></i>
                    <span>Powered by Gemini AI</span>
                </div>
            </div>

        </aside>

        <!-- Mobile hamburger toggle -->
        <button class="sidebar-toggle" id="sidebarToggle" aria-label="Toggle sidebar">
            <i class="bi bi-list"></i>
        </button>

        <!-- Main content -->
        <main class="main-content">

            <!-- Sticky header -->
            <header class="content-header">
                <div class="header-left">
                    <h1 class="page-title">@ViewData["Title"]</h1>
                    @if (ViewData["Subtitle"] != null)
                    {
                        <p class="page-subtitle">@ViewData["Subtitle"]</p>
                    }
                </div>
                <div class="header-right">
                    <div class="header-time">
                        <i class="bi bi-clock"></i>
                        <span id="currentTime"></span>
                    </div>
                    <div class="header-app-badge">
                        <i class="bi bi-lightning-charge-fill"></i>
                        <span>JobFlow AI</span>
                    </div>
                </div>
            </header>

            <!-- Flash alerts -->
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-dismissible fade show layout-alert alert-success" role="alert">
                    <i class="bi bi-check-circle-fill"></i>
                    @TempData["Success"]
                    <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-dismissible fade show layout-alert alert-danger" role="alert">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    @TempData["Error"]
                    <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <!-- Page body -->
            <div class="content-body">
                @RenderBody()
            </div>

        </main>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        // ── Live clock ──────────────────────────────────────────────
        function updateClock() {
            var el = document.getElementById('currentTime');
            if (!el) return;
            var now = new Date();
            var h = now.getHours().toString().padStart(2, '0');
            var m = now.getMinutes().toString().padStart(2, '0');
            var s = now.getSeconds().toString().padStart(2, '0');
            el.textContent = h + ':' + m + ':' + s;
        }
        updateClock();
        setInterval(updateClock, 1000);

        // ── Sidebar toggle (mobile) ─────────────────────────────────
        var sidebar  = document.getElementById('sidebar');
        var backdrop = document.getElementById('sidebarBackdrop');
        var toggle   = document.getElementById('sidebarToggle');

        function openSidebar() {
            if (!sidebar) return;
            sidebar.classList.add('show');
            if (backdrop) {
                backdrop.style.display = 'block';
                requestAnimationFrame(function () {
                    backdrop.classList.add('active');
                });
            }
        }

        function closeSidebar() {
            if (!sidebar) return;
            sidebar.classList.remove('show');
            if (backdrop) {
                backdrop.classList.remove('active');
                setTimeout(function () { backdrop.style.display = 'none'; }, 320);
            }
        }

        if (toggle) {
            toggle.addEventListener('click', function () {
                if (sidebar && sidebar.classList.contains('show')) {
                    closeSidebar();
                } else {
                    openSidebar();
                }
            });
        }

        if (backdrop) {
            backdrop.addEventListener('click', closeSidebar);
        }

        window.addEventListener('resize', function () {
            if (window.innerWidth >= 992) {
                closeSidebar();
            }
        });

        // ── Active nav link detection ───────────────────────────────
        (function () {
            var path = window.location.pathname.toLowerCase();
            var links = document.querySelectorAll('.sidebar-nav .nav-link');
            var bestMatch = null;
            var bestLen   = 0;

            links.forEach(function (link) {
                if (link.classList.contains('nav-logout')) return;
                var href = (link.getAttribute('href') || '').toLowerCase();
                if (href && href !== '#' && path.startsWith(href) && href.length > bestLen) {
                    bestLen   = href.length;
                    bestMatch = link;
                }
            });

            links.forEach(function (link) { link.classList.remove('active'); });

            if (bestMatch) {
                bestMatch.classList.add('active');
            }
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
