<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - JobFlow AI</title>
    <meta name="description" content="AI-powered job application automation tool" />

    <!-- Google Font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="app-container">
        <!-- Sidebar -->
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <div class="sidebar-brand">
                    <div class="brand-icon">
                        <i class="bi bi-briefcase-fill"></i>
                    </div>
                    <div class="brand-text">
                        <span class="brand-name">JobFlow</span>
                        <span class="brand-badge">AI</span>
                    </div>
                </div>
            </div>

            <nav class="sidebar-nav">
                <div class="nav-section">
                    <span class="nav-section-title">Main</span>
                    <a href="@Url.Action("Index", "Dashboard")" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                        <i class="bi bi-grid-1x2-fill"></i>
                        <span>Dashboard</span>
                    </a>
                    <a href="@Url.Action("Index", "Upload")" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Upload" ? "active" : "")">
                        <i class="bi bi-cloud-arrow-up-fill"></i>
                        <span>Upload</span>
                    </a>
                </div>

                <div class="nav-section">
                    <span class="nav-section-title">Emails</span>
                    <a href="@Url.Action("History", "Email")" class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "History" ? "active" : "")">
                        <i class="bi bi-envelope-fill"></i>
                        <span>Email History</span>
                    </a>
                    <a href="@Url.Action("Export", "Email")" class="nav-link">
                        <i class="bi bi-download"></i>
                        <span>Export CSV</span>
                    </a>
                </div>

                <div class="nav-section">
                    <span class="nav-section-title">Settings</span>
                    <a href="@Url.Action("Index", "Resume")" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Resume" ? "active" : "")">
                        <i class="bi bi-file-earmark-person-fill"></i>
                        <span>Resume & Profile</span>
                    </a>
                    <a href="@Url.Action("Index", "Telegram")" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Telegram" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                        <i class="bi bi-telegram"></i>
                        <span>Telegram Bot</span>
                    </a>
                    <a href="@Url.Action("Progress", "Telegram")" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Telegram" && ViewContext.RouteData.Values["action"]?.ToString() == "Progress" ? "active" : "")">
                        <i class="bi bi-activity"></i>
                        <span>Live Activity</span>
                    </a>
                    <a href="@Url.Action("Logout", "Login")" class="nav-link text-danger mt-4" style="border-top: 1px solid rgba(255, 255, 255, 0.05); padding-top: 15px;">
                        <i class="bi bi-box-arrow-right text-danger"></i>
                        <span>Logout</span>
                    </a>
                </div>
            </nav>

            <div class="sidebar-footer">
                <div class="sidebar-footer-content">
                    <i class="bi bi-robot"></i>
                    <span>Powered by Gemini AI</span>
                </div>
            </div>
        </aside>

        <!-- Mobile toggle -->
        <button class="sidebar-toggle d-lg-none" id="sidebarToggle">
            <i class="bi bi-list"></i>
        </button>

        <!-- Main content -->
        <main class="main-content">
            <header class="content-header">
                <div class="header-left">
                    <h1 class="page-title">@ViewData["Title"]</h1>
                    @if (ViewData["Subtitle"] != null)
                    {
                        <p class="page-subtitle">@ViewData["Subtitle"]</p>
                    }
                </div>
                <div class="header-right">
                    <div class="header-time">
                        <i class="bi bi-clock"></i>
                        <span id="currentTime"></span>
                    </div>
                </div>
            </header>

            <!-- Notifications -->
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show mx-4 mt-3" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show mx-4 mt-3" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="content-body">
                @RenderBody()
            </div>
        </main>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
