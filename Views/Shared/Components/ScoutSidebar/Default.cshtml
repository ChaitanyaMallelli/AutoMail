@using JobAutomation.Models
@model List<JobAutomation.Models.ScoutedJob>

<div class="nav-section mt-2">
    <span class="nav-section-title d-flex align-items-center justify-content-between">
        <span><i class="bi bi-robot me-1"></i> LinkedIn Scout</span>
        <span class="badge rounded-pill scout-sidebar-live-badge">
            @Model.Count(j => j.Status == ScoutedJobStatus.SentToTelegram) live
        </span>
    </span>

    @if (!Model.Any())
    {
        <div class="scout-sidebar-empty">
            <i class="bi bi-clock-history me-1"></i> No jobs scouted yet
        </div>
    }
    else
    {
        <div class="scout-sidebar-list">
            @foreach (var job in Model)
            {
                var dotClass = job.Status switch {
                    ScoutedJobStatus.SentToTelegram  => "scout-dot--sent",
                    ScoutedJobStatus.Applied         => "scout-dot--applied",
                    ScoutedJobStatus.IgnoredByGemini => "scout-dot--ignored",
                    _                                => "scout-dot--default"
                };
                var statusIcon = job.Status switch {
                    ScoutedJobStatus.SentToTelegram  => "bi-send-fill",
                    ScoutedJobStatus.Applied         => "bi-check-circle-fill",
                    ScoutedJobStatus.IgnoredByGemini => "bi-x-circle",
                    _                                => "bi-circle"
                };
                var preview = job.RawText != null && job.RawText.Length > 45
                    ? job.RawText.Substring(0, 45) + "…"
                    : job.RawText ?? "No preview";

                <a href="@job.LinkedInUrl" target="_blank"
                   class="scout-sidebar-item"
                   title="@job.RawText">
                    <div class="scout-sidebar-dot @dotClass">
                        <i class="bi @statusIcon"></i>
                    </div>
                    <div class="scout-sidebar-text">
                        <span class="scout-sidebar-keyword">@job.KeywordMatched <span style="opacity:0.6;font-weight:400;">· @(job.Board ?? "LinkedIn")</span></span>
                        <span class="scout-sidebar-preview">@preview</span>
                        <span class="scout-sidebar-time">@job.CreatedAt.ToIst().ToString("MMM dd, HH:mm")</span>
                    </div>
                </a>
            }
        </div>

        <a href="@Url.Action("Index", "Dashboard")#scout-logs"
           class="nav-link scout-sidebar-view-all">
            <i class="bi bi-arrow-right-circle me-1"></i>
            <span>View All Scout Logs</span>
        </a>
    }
</div>
