@model JobAutomation.Models.Resume
@{
    ViewData["Title"] = "Resume & Profile";
    ViewData["Subtitle"] = "Manage your resumes and personal info used for job applications";
    var profile = ViewBag.Profile as JobAutomation.Models.UserProfile;
    var allResumes = ViewBag.Resumes as List<JobAutomation.Models.Resume> ?? new List<JobAutomation.Models.Resume>();

    var activeSkills = new List<string>();
    if (Model?.Skills != null)
    {
        try { activeSkills = Newtonsoft.Json.JsonConvert.DeserializeObject<List<string>>(Model.Skills) ?? new List<string>(); }
        catch { }
    }
}

<style>
    /* ── Section cards ── */
    .resume-card {
        background: rgba(14, 22, 40, 0.72);
        border: 1px solid rgba(148, 163, 184, 0.09);
        border-radius: 14px;
        backdrop-filter: blur(16px);
        box-shadow: 0 4px 32px rgba(0, 0, 0, 0.28);
        padding: 28px;
    }

    .resume-card-header {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 22px;
        padding-bottom: 16px;
        border-bottom: 1px solid rgba(148, 163, 184, 0.07);
    }

    .resume-card-header .header-icon {
        width: 36px;
        height: 36px;
        border-radius: 9px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        flex-shrink: 0;
    }

    .resume-card-header .header-icon.icon-purple {
        background: rgba(99, 102, 241, 0.15);
        color: #a5b4fc;
    }

    .resume-card-header .header-icon.icon-teal {
        background: rgba(20, 184, 166, 0.13);
        color: #5eead4;
    }

    .resume-card-header .header-icon.icon-amber {
        background: rgba(245, 158, 11, 0.13);
        color: #fbbf24;
    }

    .resume-card-header h5 {
        margin: 0;
        font-size: 15px;
        font-weight: 700;
        color: #e2e8f0;
        letter-spacing: -0.2px;
    }

    .resume-card-header p {
        margin: 0;
        font-size: 12px;
        color: #64748b;
        margin-top: 1px;
    }

    /* ── Form labels & inputs ── */
    .field-label {
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.6px;
        color: #94a3b8;
        margin-bottom: 6px;
        display: block;
    }

    .field-hint {
        font-size: 11.5px;
        color: #475569;
        margin-top: 5px;
    }

    /* ── File drop zone ── */
    .file-drop-zone {
        border: 2px dashed rgba(99, 102, 241, 0.25);
        border-radius: 10px;
        padding: 20px;
        text-align: center;
        background: rgba(99, 102, 241, 0.04);
        cursor: pointer;
        transition: all 0.2s ease;
        position: relative;
    }
    .file-drop-zone:hover,
    .file-drop-zone.dragover {
        border-color: rgba(99, 102, 241, 0.55);
        background: rgba(99, 102, 241, 0.08);
    }
    .file-drop-zone input[type="file"] {
        position: absolute;
        inset: 0;
        opacity: 0;
        cursor: pointer;
        width: 100%;
        height: 100%;
    }
    .file-drop-zone .drop-icon {
        font-size: 28px;
        color: #6366f1;
        margin-bottom: 8px;
        display: block;
        opacity: 0.75;
    }
    .file-drop-zone .drop-label {
        font-size: 13px;
        font-weight: 600;
        color: #c7d2fe;
    }
    .file-drop-zone .drop-sub {
        font-size: 11.5px;
        color: #475569;
        margin-top: 3px;
    }
    #fileNameDisplay {
        font-size: 12px;
        color: #4ade80;
        margin-top: 8px;
        font-weight: 500;
        min-height: 18px;
    }

    /* ── Auto-parse button ── */
    .btn-parse {
        background: linear-gradient(135deg, rgba(99,102,241,0.18) 0%, rgba(139,92,246,0.18) 100%);
        border: 1px solid rgba(99, 102, 241, 0.35);
        color: #a5b4fc;
        font-size: 12.5px;
        font-weight: 600;
        padding: 8px 16px;
        border-radius: 8px;
        transition: all 0.2s ease;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }
    .btn-parse:hover {
        background: linear-gradient(135deg, rgba(99,102,241,0.30) 0%, rgba(139,92,246,0.30) 100%);
        border-color: rgba(99, 102, 241, 0.65);
        color: #c7d2fe;
    }
    .btn-parse:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    /* ── History table ── */
    .resume-table {
        --bs-table-bg: transparent;
        --bs-table-border-color: rgba(148, 163, 184, 0.06);
        font-size: 13px;
    }
    .resume-table thead th {
        font-size: 10.5px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.7px;
        color: #475569;
        padding: 10px 14px;
        border-bottom: 1px solid rgba(148, 163, 184, 0.08);
        background: rgba(8, 13, 28, 0.40);
    }
    .resume-table tbody tr {
        border-bottom: 1px solid rgba(148, 163, 184, 0.04);
        transition: background 0.15s ease;
    }
    .resume-table tbody tr:hover {
        background: rgba(99, 102, 241, 0.05);
    }
    .resume-table tbody td {
        padding: 12px 14px;
        vertical-align: middle;
        color: #cbd5e1;
    }

    /* ── Status badges ── */
    .badge-active {
        background: rgba(34, 197, 94, 0.12);
        border: 1px solid rgba(34, 197, 94, 0.25);
        color: #4ade80;
        font-size: 10.5px;
        font-weight: 700;
        padding: 3px 9px;
        border-radius: 9999px;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        letter-spacing: 0.3px;
    }
    .badge-inactive {
        background: rgba(100, 116, 139, 0.10);
        border: 1px solid rgba(100, 116, 139, 0.18);
        color: #64748b;
        font-size: 10.5px;
        font-weight: 600;
        padding: 3px 9px;
        border-radius: 9999px;
        letter-spacing: 0.3px;
    }

    /* ── Action buttons in table ── */
    .tbl-btn {
        padding: 5px 10px;
        font-size: 11.5px;
        font-weight: 600;
        border-radius: 7px;
        transition: all 0.18s ease;
        line-height: 1.2;
    }

    /* ── Active resume preview ── */
    .active-preview {
        background: rgba(99, 102, 241, 0.05);
        border: 1px solid rgba(99, 102, 241, 0.14);
        border-radius: 10px;
        padding: 16px;
    }

    .skill-tag {
        display: inline-flex;
        align-items: center;
        background: rgba(99, 102, 241, 0.12);
        border: 1px solid rgba(99, 102, 241, 0.22);
        color: #c7d2fe;
        font-size: 11px;
        font-weight: 600;
        padding: 3px 10px;
        border-radius: 9999px;
        white-space: nowrap;
    }

    /* ── Profile avatar circle ── */
    .profile-avatar {
        width: 56px;
        height: 56px;
        border-radius: 14px;
        background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        color: #fff;
        box-shadow: 0 0 18px rgba(99, 102, 241, 0.35);
        flex-shrink: 0;
    }

    /* ── Input icon group ── */
    .input-icon-group {
        position: relative;
    }
    .input-icon-group .input-icon {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: #475569;
        font-size: 14px;
        pointer-events: none;
        z-index: 2;
    }
    .input-icon-group .form-control,
    .input-icon-group .form-select {
        padding-left: 36px;
    }
    .input-icon-group.textarea-group .input-icon {
        top: 14px;
        transform: none;
    }
    .input-icon-group.textarea-group .form-control {
        padding-left: 36px;
    }

    /* ── Divider ── */
    .section-divider {
        border: none;
        border-top: 1px solid rgba(148, 163, 184, 0.07);
        margin: 20px 0;
    }

    /* ── Empty state ── */
    .empty-state {
        text-align: center;
        padding: 36px 20px;
    }
    .empty-state-icon {
        width: 64px;
        height: 64px;
        border-radius: 16px;
        background: rgba(99, 102, 241, 0.08);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 26px;
        color: #6366f1;
        margin: 0 auto 16px;
        opacity: 0.7;
    }
</style>

<div class="row g-4">

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- LEFT COLUMN: Resume Management                              -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <div class="col-xl-7 col-lg-6">

        <!-- ── Active Resume Preview (shown when a resume exists) ── -->
        @if (Model != null)
        {
            <div class="resume-card mb-4">
                <div class="resume-card-header">
                    <div class="header-icon icon-amber">
                        <i class="bi bi-file-earmark-check-fill"></i>
                    </div>
                    <div>
                        <h5>Active Resume</h5>
                        <p>Currently selected for job matching</p>
                    </div>
                    <span class="badge-active ms-auto">
                        <i class="bi bi-circle-fill" style="font-size:6px;"></i> Default
                    </span>
                </div>

                @if (activeSkills.Count > 0)
                {
                    <div class="mb-3">
                        <span class="field-label">Skills</span>
                        <div class="d-flex flex-wrap gap-2 mt-1">
                            @foreach (var skill in activeSkills)
                            {
                                <span class="skill-tag">@skill.Trim()</span>
                            }
                        </div>
                    </div>
                    <hr class="section-divider" />
                }

                <div class="row g-3">
                    @if (!string.IsNullOrWhiteSpace(Model.Experience))
                    {
                        <div class="col-md-6">
                            <span class="field-label">Experience Summary</span>
                            <p class="text-sm mb-0" style="color: #94a3b8; line-height: 1.55;">@Model.Experience</p>
                        </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.Education))
                    {
                        <div class="col-md-6">
                            <span class="field-label">Education</span>
                            <p class="text-sm mb-0" style="color: #94a3b8; line-height: 1.55;">@Model.Education</p>
                        </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.FilePath))
                    {
                        <div class="col-12">
                            <span class="field-label">File</span>
                            <div class="d-flex align-items-center gap-2 mt-1">
                                <i class="bi bi-file-earmark-pdf-fill text-danger" style="font-size:15px;"></i>
                                <span class="text-sm" style="color:#94a3b8;">@System.IO.Path.GetFileName(Model.FilePath)</span>
                                <a href="@Url.Action("ViewFile", "Resume", new { id = Model.Id })" target="_blank"
                                   class="btn btn-sm btn-outline-secondary tbl-btn ms-auto">
                                    <i class="bi bi-box-arrow-up-right me-1"></i>View
                                </a>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- ── Upload New Resume ── -->
        <div class="resume-card mb-4">
            <div class="resume-card-header">
                <div class="header-icon icon-purple">
                    <i class="bi bi-cloud-arrow-up-fill"></i>
                </div>
                <div>
                    <h5>Upload New Resume</h5>
                    <p>Add a PDF and let AI extract your details automatically</p>
                </div>
            </div>

            <form method="post" asp-action="Upload" enctype="multipart/form-data" id="uploadForm">
                <div class="row g-3">

                    <!-- File picker -->
                    <div class="col-12">
                        <label class="field-label">Resume PDF</label>
                        <div class="file-drop-zone" id="fileDropZone">
                            <input type="file" id="resumeFileInput" name="resumeFile" accept=".pdf" required />
                            <i class="bi bi-file-earmark-arrow-up drop-icon"></i>
                            <div class="drop-label">Drop your PDF here or click to browse</div>
                            <div class="drop-sub">Only PDF files are accepted</div>
                        </div>
                        <div id="fileNameDisplay"></div>

                        <!-- Auto-parse button sits right below file picker -->
                        <button type="button" class="btn-parse mt-3" id="autoParseBtn">
                            <i class="bi bi-stars"></i>
                            Auto-Parse with AI
                        </button>
                        <span class="field-hint ms-2">Extracts skills, experience & education from the PDF.</span>
                    </div>

                    <!-- Full text -->
                    <div class="col-12">
                        <label class="field-label" for="fullTextInput">Resume Full Text</label>
                        <div class="input-icon-group textarea-group">
                            <i class="bi bi-text-left input-icon"></i>
                            <textarea id="fullTextInput" name="fullText" class="form-control" rows="6"
                                      placeholder="Paste your full resume text here, or use Auto-Parse above to fill it automatically..." required></textarea>
                        </div>
                        <div class="field-hint">Used for AI-powered job match scoring.</div>
                    </div>

                    <!-- Skills -->
                    <div class="col-12">
                        <label class="field-label" for="skillsInput">
                            Skills
                            <span style="font-weight:400; text-transform:none; letter-spacing:0; color:#64748b; font-size:11px;">— comma-separated</span>
                        </label>
                        <div class="input-icon-group">
                            <i class="bi bi-tags input-icon"></i>
                            <input id="skillsInput" type="text" name="skills" class="form-control"
                                   placeholder="e.g. C#, .NET Core, React, SQL Server, Docker, Azure..." />
                        </div>
                        <div class="field-hint">Separate each skill with a comma. Auto-Parse will fill this in for you.</div>
                    </div>

                    <!-- Experience + Education -->
                    <div class="col-md-6">
                        <label class="field-label" for="experienceInput">Work Experience</label>
                        <div class="input-icon-group textarea-group">
                            <i class="bi bi-briefcase input-icon"></i>
                            <textarea id="experienceInput" name="experience" class="form-control" rows="4"
                                      placeholder="e.g. 3 years as a Software Engineer at Acme Corp, building REST APIs..."></textarea>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <label class="field-label" for="educationInput">Education</label>
                        <div class="input-icon-group textarea-group">
                            <i class="bi bi-mortarboard input-icon"></i>
                            <textarea id="educationInput" name="education" class="form-control" rows="4"
                                      placeholder="e.g. B.Tech in Computer Science, JNTU Hyderabad, 2022..."></textarea>
                        </div>
                    </div>

                    <!-- Submit -->
                    <div class="col-12 pt-1">
                        <button type="submit" class="btn btn-glow w-100 py-2" style="font-size:14px; font-weight:700;">
                            <i class="bi bi-plus-circle-fill me-2"></i>Upload & Activate Resume
                        </button>
                    </div>

                </div>
            </form>
        </div>

        <!-- ── Resume History ── -->
        <div class="resume-card">
            <div class="resume-card-header">
                <div class="header-icon icon-teal">
                    <i class="bi bi-clock-history"></i>
                </div>
                <div>
                    <h5>Resume History</h5>
                    <p>@allResumes.Count resume@(allResumes.Count == 1 ? "" : "s") uploaded</p>
                </div>
            </div>

            @if (allResumes.Count == 0)
            {
                <div class="empty-state">
                    <div class="empty-state-icon">
                        <i class="bi bi-file-earmark-pdf"></i>
                    </div>
                    <p class="fw-semibold mb-1" style="color:#cbd5e1;">No resumes uploaded yet</p>
                    <p class="text-sm" style="color:#475569; max-width:280px; margin: 0 auto;">Use the upload panel above to add your first resume.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-dark resume-table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>File</th>
                                <th>Uploaded</th>
                                <th class="text-center">Status</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var resume in allResumes)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div style="width:30px; height:30px; border-radius:7px; background:rgba(239,68,68,0.12); display:flex; align-items:center; justify-content:center; color:#f87171; font-size:14px; flex-shrink:0;">
                                                <i class="bi bi-file-earmark-pdf-fill"></i>
                                            </div>
                                            <div>
                                                <span class="fw-semibold d-block" style="color:#e2e8f0; font-size:12.5px;">
                                                    @(string.IsNullOrEmpty(resume.FilePath) ? "Text-Only Profile" : System.IO.Path.GetFileName(resume.FilePath))
                                                </span>
                                                @if (!string.IsNullOrWhiteSpace(resume.Experience))
                                                {
                                                    <span style="font-size:11px; color:#475569; display:block; max-width:180px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                                                        @(resume.Experience.Length > 45 ? resume.Experience.Substring(0, 45) + "…" : resume.Experience)
                                                    </span>
                                                }
                                            </div>
                                        </div>
                                    </td>
                                    <td style="color:#64748b; font-size:12px; white-space:nowrap;">
                                        @resume.UploadedAt.ToIst().ToString("MMM dd, yyyy HH:mm")
                                    </td>
                                    <td class="text-center">
                                        @if (resume.IsActive)
                                        {
                                            <span class="badge-active">
                                                <i class="bi bi-circle-fill" style="font-size:6px;"></i> Active
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge-inactive">Inactive</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <div class="d-inline-flex align-items-center gap-1">
                                            @if (!resume.IsActive)
                                            {
                                                <form method="post" asp-action="SetDefault" asp-route-id="@resume.Id" class="d-inline">
                                                    <button type="submit" class="btn btn-sm btn-outline-light tbl-btn" title="Set as default resume">
                                                        <i class="bi bi-check2-circle me-1"></i>Set Default
                                                    </button>
                                                </form>
                                            }
                                            @if (!string.IsNullOrEmpty(resume.FilePath))
                                            {
                                                <a href="@Url.Action("ViewFile", "Resume", new { id = resume.Id })" target="_blank"
                                                   class="btn btn-sm btn-outline-secondary tbl-btn" title="View PDF">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                            }
                                            <form method="post" asp-action="Delete" asp-route-id="@resume.Id" class="d-inline"
                                                  onsubmit="return confirm('Delete this resume permanently?');">
                                                <button type="submit" class="btn btn-sm btn-outline-danger tbl-btn" title="Delete">
                                                    <i class="bi bi-trash3"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

    </div>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- RIGHT COLUMN: User Profile                                  -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <div class="col-xl-5 col-lg-6">

        <div class="resume-card" style="position: sticky; top: 24px;">

            <!-- Profile header with avatar -->
            <div class="resume-card-header">
                <div class="profile-avatar">
                    <i class="bi bi-person-fill"></i>
                </div>
                <div>
                    <h5>Personal Profile</h5>
                    <p>Contact details used in outreach emails</p>
                </div>
            </div>

            <form method="post" asp-action="UpdateProfile">
                <div class="row g-3">

                    <!-- Full Name -->
                    <div class="col-12">
                        <label class="field-label" for="fullNameInput">Full Name</label>
                        <div class="input-icon-group">
                            <i class="bi bi-person input-icon"></i>
                            <input id="fullNameInput" type="text" name="fullName" class="form-control"
                                   value="@(profile?.FullName)"
                                   placeholder="e.g. Chaitanya Mallelli"
                                   required />
                        </div>
                    </div>

                    <!-- Email -->
                    <div class="col-12">
                        <label class="field-label" for="emailInput">Email Address</label>
                        <div class="input-icon-group">
                            <i class="bi bi-envelope input-icon"></i>
                            <input id="emailInput" type="email" name="email" class="form-control"
                                   value="@(profile?.Email)"
                                   placeholder="e.g. you@example.com"
                                   required />
                        </div>
                        <div class="field-hint">Used as the sender address in Gmail outreach emails.</div>
                    </div>

                    <!-- Phone -->
                    <div class="col-12">
                        <label class="field-label" for="phoneInput">Phone Number</label>
                        <div class="input-icon-group">
                            <i class="bi bi-telephone input-icon"></i>
                            <input id="phoneInput" type="text" name="phone" class="form-control"
                                   value="@(profile?.Phone)"
                                   placeholder="e.g. +91 98765 43210" />
                        </div>
                    </div>

                    <!-- LinkedIn -->
                    <div class="col-12">
                        <label class="field-label" for="linkedInInput">LinkedIn Profile URL</label>
                        <div class="input-icon-group">
                            <i class="bi bi-linkedin input-icon"></i>
                            <input id="linkedInInput" type="url" name="linkedInUrl" class="form-control"
                                   value="@(profile?.LinkedInUrl)"
                                   placeholder="https://linkedin.com/in/your-handle" />
                        </div>
                        <div class="field-hint">Included in application emails so recruiters can view your profile.</div>
                    </div>

                    <hr class="section-divider mb-0" />

                    <!-- Save -->
                    <div class="col-12">
                        <button type="submit" class="btn btn-glow w-100 py-2" style="font-size:14px; font-weight:700;">
                            <i class="bi bi-check-circle-fill me-2"></i>Save Profile
                        </button>
                    </div>

                </div>
            </form>

            <!-- Quick info strip if profile is populated -->
            @if (profile != null && (!string.IsNullOrWhiteSpace(profile.FullName) || !string.IsNullOrWhiteSpace(profile.Email)))
            {
                <hr class="section-divider" />
                <div style="background: rgba(20, 184, 166, 0.06); border: 1px solid rgba(20, 184, 166, 0.12); border-radius: 9px; padding: 14px;">
                    <p class="field-label mb-2" style="color:#5eead4;">
                        <i class="bi bi-shield-check me-1"></i>Saved Profile
                    </p>
                    @if (!string.IsNullOrWhiteSpace(profile.FullName))
                    {
                        <p class="text-sm mb-1" style="color:#94a3b8;">
                            <i class="bi bi-person-fill me-2" style="color:#475569;"></i>@profile.FullName
                        </p>
                    }
                    @if (!string.IsNullOrWhiteSpace(profile.Email))
                    {
                        <p class="text-sm mb-1" style="color:#94a3b8;">
                            <i class="bi bi-envelope-fill me-2" style="color:#475569;"></i>@profile.Email
                        </p>
                    }
                    @if (!string.IsNullOrWhiteSpace(profile.Phone))
                    {
                        <p class="text-sm mb-1" style="color:#94a3b8;">
                            <i class="bi bi-telephone-fill me-2" style="color:#475569;"></i>@profile.Phone
                        </p>
                    }
                    @if (!string.IsNullOrWhiteSpace(profile.LinkedInUrl))
                    {
                        <p class="text-sm mb-0" style="color:#94a3b8;">
                            <i class="bi bi-linkedin me-2" style="color:#475569;"></i>
                            <a href="@profile.LinkedInUrl" target="_blank" style="color:#7dd3fc; text-decoration:none;">View LinkedIn</a>
                        </p>
                    }
                </div>
            }

        </div>
    </div>

</div>

@section Scripts {
    <script>
        // ── File picker: show filename and update drop zone ──────────────
        const fileInput   = document.getElementById('resumeFileInput');
        const dropZone    = document.getElementById('fileDropZone');
        const fileDisplay = document.getElementById('fileNameDisplay');

        fileInput.addEventListener('change', function () {
            const file = this.files[0];
            if (file) {
                fileDisplay.innerHTML = '<i class="bi bi-file-earmark-pdf-fill text-danger me-1"></i>' + file.name;
                dropZone.style.borderColor = 'rgba(99, 102, 241, 0.6)';
                dropZone.style.background  = 'rgba(99, 102, 241, 0.10)';
            } else {
                fileDisplay.textContent = '';
                dropZone.style.borderColor = '';
                dropZone.style.background  = '';
            }
        });

        // Drag-over visual feedback
        dropZone.addEventListener('dragover', function (e) {
            e.preventDefault();
            this.classList.add('dragover');
        });
        dropZone.addEventListener('dragleave', function () {
            this.classList.remove('dragover');
        });
        dropZone.addEventListener('drop', function () {
            this.classList.remove('dragover');
        });

        // ── Auto-parse button ─────────────────────────────────────────────
        document.getElementById('autoParseBtn').addEventListener('click', async function () {
            const file = fileInput.files[0];

            if (!file) {
                showToast('Please select a PDF file first.', 'warning');
                return;
            }
            if (file.type !== 'application/pdf') {
                showToast('Only PDF files are supported for auto-parsing.', 'warning');
                return;
            }

            const btn = this;
            const originalHTML = btn.innerHTML;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm" style="width:13px;height:13px;border-width:2px;"></span> Parsing with AI...';
            btn.disabled = true;

            const formData = new FormData();
            formData.append('resumeFile', file);

            try {
                const response = await fetch('@Url.Action("AutoParse", "Resume")', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();

                if (result.success) {
                    document.getElementById('fullTextInput').value   = result.fullText   || '';
                    document.getElementById('skillsInput').value     = result.skills     || '';
                    document.getElementById('experienceInput').value = result.experience || '';
                    document.getElementById('educationInput').value  = result.education  || '';
                    showToast('Resume parsed successfully. Please review the fields before uploading.', 'success');
                } else {
                    showToast('Parse failed: ' + (result.message || 'Unknown error'), 'danger');
                }
            } catch (err) {
                console.error(err);
                showToast('A network error occurred during parsing.', 'danger');
            } finally {
                btn.innerHTML = originalHTML;
                btn.disabled = false;
            }
        });

        // ── Simple inline toast helper ────────────────────────────────────
        function showToast(message, type) {
            const colors = {
                success: { bg: 'rgba(34,197,94,0.10)', border: 'rgba(34,197,94,0.28)', color: '#4ade80' },
                warning: { bg: 'rgba(245,158,11,0.10)', border: 'rgba(245,158,11,0.28)', color: '#fbbf24' },
                danger:  { bg: 'rgba(239,68,68,0.10)',  border: 'rgba(239,68,68,0.28)',  color: '#f87171' }
            };
            const c = colors[type] || colors.success;

            const el = document.createElement('div');
            el.style.cssText = [
                'position:fixed', 'top:20px', 'right:24px', 'z-index:9999',
                'padding:12px 18px', 'border-radius:10px', 'font-size:13.5px', 'font-weight:500',
                'max-width:340px', 'box-shadow:0 8px 32px rgba(0,0,0,0.35)',
                'transition:opacity 0.35s ease', 'opacity:0',
                'background:' + c.bg, 'border:1px solid ' + c.border, 'color:' + c.color
            ].join(';');
            el.textContent = message;

            document.body.appendChild(el);
            requestAnimationFrame(() => { el.style.opacity = '1'; });
            setTimeout(() => {
                el.style.opacity = '0';
                setTimeout(() => el.remove(), 380);
            }, 4200);
        }
    </script>
}
