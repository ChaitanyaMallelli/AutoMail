@model JobAutomation.Models.Resume
@{
    ViewData["Title"] = "Resume & Profile";
    ViewData["Subtitle"] = "Manage your resumes and personal info used for job applications";
    var profile = ViewBag.Profile as JobAutomation.Models.UserProfile;
    var allResumes = ViewBag.Resumes as List<JobAutomation.Models.Resume> ?? new List<JobAutomation.Models.Resume>();

    var activeSkills = new List<string>();
    if (Model?.Skills != null)
    {
        try { activeSkills = Newtonsoft.Json.JsonConvert.DeserializeObject<List<string>>(Model.Skills) ?? new List<string>(); }
        catch { }
    }
}

<style>
    /* ── Base tokens ── */
    :root {
        --bg-base:        #09090b;
        --bg-elevated:    #111118;
        --bg-card:        #16161f;
        --border:         rgba(255,255,255,0.07);
        --border-hover:   rgba(124,58,237,0.35);
        --accent-violet:  #7c3aed;
        --accent-indigo:  #6366f1;
        --accent-pink:    #ec4899;
        --grad-primary:   linear-gradient(135deg,#7c3aed 0%,#6366f1 100%);
        --grad-hot:       linear-gradient(135deg,#ec4899 0%,#7c3aed 100%);
        --glow-violet:    0 0 20px rgba(124,58,237,0.35);
        --glow-sm:        0 0 12px rgba(124,58,237,0.20);
        --text-primary:   #f4f4f5;
        --text-secondary: #a1a1aa;
        --text-muted:     #52525b;
        --success:        #22c55e;
        --success-bg:     rgba(34,197,94,0.12);
        --warning:        #f59e0b;
        --warning-bg:     rgba(245,158,11,0.12);
        --danger:         #ef4444;
        --danger-bg:      rgba(239,68,68,0.12);
        --info:           #3b82f6;
        --info-bg:        rgba(59,130,246,0.12);
        --r-sm:  6px;
        --r-md:  10px;
        --r-lg:  14px;
        --r-xl:  20px;
    }

    /* ── Panel card ── */
    .rp-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--r-xl);
        padding: 28px;
        box-shadow: 0 4px 40px rgba(0,0,0,0.45);
        transition: border-color 0.2s ease;
    }

    /* ── Section header row ── */
    .rp-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 24px;
        padding-bottom: 18px;
        border-bottom: 1px solid var(--border);
    }
    .rp-header-icon {
        width: 40px;
        height: 40px;
        border-radius: var(--r-md);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 17px;
        flex-shrink: 0;
        background: var(--grad-primary);
        box-shadow: var(--glow-sm);
        color: #fff;
    }
    .rp-header-icon.icon-hot {
        background: var(--grad-hot);
        box-shadow: 0 0 12px rgba(236,72,153,0.25);
    }
    .rp-header-icon.icon-teal {
        background: linear-gradient(135deg,#14b8a6 0%,#0ea5e9 100%);
        box-shadow: 0 0 12px rgba(20,184,166,0.25);
    }
    .rp-header-title {
        font-size: 15px;
        font-weight: 800;
        color: var(--text-primary);
        margin: 0;
        letter-spacing: -0.3px;
    }
    .rp-header-sub {
        font-size: 12px;
        color: var(--text-muted);
        margin: 2px 0 0;
    }

    /* ── Field label ── */
    .field-label {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.7px;
        color: var(--text-secondary);
        margin-bottom: 7px;
        display: block;
    }
    .field-hint {
        font-size: 11.5px;
        color: var(--text-muted);
        margin-top: 5px;
    }

    /* ── Form controls ── */
    .form-control,
    .form-select {
        background: var(--bg-elevated) !important;
        border: 1px solid var(--border) !important;
        border-radius: var(--r-md) !important;
        color: var(--text-primary) !important;
        font-size: 13.5px !important;
        padding: 10px 14px !important;
        transition: border-color 0.2s ease, box-shadow 0.2s ease !important;
    }
    .form-control:focus,
    .form-select:focus {
        border-color: var(--border-hover) !important;
        box-shadow: var(--glow-sm) !important;
        outline: none !important;
        background: var(--bg-card) !important;
    }
    .form-control::placeholder { color: var(--text-muted) !important; }

    /* ── Input with icon ── */
    .input-icon-group { position: relative; }
    .input-icon-group .ii {
        position: absolute;
        left: 13px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-muted);
        font-size: 14px;
        pointer-events: none;
        z-index: 2;
    }
    .input-icon-group.ta-group .ii { top: 13px; transform: none; }
    .input-icon-group .form-control,
    .input-icon-group .form-select { padding-left: 38px !important; }

    /* ── File drop zone ── */
    .file-drop-zone {
        border: 2px dashed rgba(124,58,237,0.28);
        border-radius: var(--r-lg);
        padding: 24px 20px;
        text-align: center;
        background: rgba(124,58,237,0.04);
        cursor: pointer;
        transition: all 0.2s ease;
        position: relative;
    }
    .file-drop-zone:hover,
    .file-drop-zone.dragover {
        border-color: var(--border-hover);
        background: rgba(124,58,237,0.09);
        box-shadow: var(--glow-sm);
    }
    .file-drop-zone input[type="file"] {
        position: absolute;
        inset: 0;
        opacity: 0;
        cursor: pointer;
        width: 100%;
        height: 100%;
    }
    .drop-icon {
        font-size: 30px;
        background: var(--grad-primary);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        display: block;
        margin-bottom: 10px;
    }
    .drop-label { font-size: 13px; font-weight: 700; color: var(--text-primary); }
    .drop-sub   { font-size: 11.5px; color: var(--text-muted); margin-top: 3px; }
    #fileNameDisplay {
        font-size: 12px;
        color: var(--success);
        margin-top: 9px;
        font-weight: 600;
        min-height: 18px;
    }

    /* ── Auto-parse button ── */
    .btn-parse {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 9px 18px;
        border-radius: var(--r-md);
        font-size: 12.5px;
        font-weight: 700;
        cursor: pointer;
        border: 1px solid rgba(124,58,237,0.4);
        background: rgba(124,58,237,0.12);
        color: #c4b5fd;
        transition: all 0.2s ease;
        letter-spacing: 0.1px;
    }
    .btn-parse:hover {
        background: rgba(124,58,237,0.22);
        border-color: var(--border-hover);
        color: #ddd6fe;
        box-shadow: var(--glow-sm);
    }
    .btn-parse:disabled { opacity: 0.45; cursor: not-allowed; }

    /* ── Primary action button ── */
    .btn-primary-action {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        width: 100%;
        padding: 12px 20px;
        border-radius: var(--r-md);
        font-size: 14px;
        font-weight: 800;
        cursor: pointer;
        border: none;
        background: var(--grad-primary);
        color: #fff;
        letter-spacing: -0.1px;
        transition: all 0.2s ease;
        box-shadow: 0 4px 20px rgba(124,58,237,0.30);
    }
    .btn-primary-action:hover {
        transform: translateY(-1px);
        box-shadow: var(--glow-violet);
        filter: brightness(1.08);
    }
    .btn-primary-action:active { transform: translateY(0); }

    /* ── Active resume preview box ── */
    .active-preview {
        background: rgba(124,58,237,0.06);
        border: 1px solid rgba(124,58,237,0.18);
        border-radius: var(--r-lg);
        padding: 18px;
    }
    .active-preview-title {
        font-size: 13.5px;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 3px;
    }
    .active-preview-sub {
        font-size: 11.5px;
        color: var(--text-muted);
    }

    /* ── Skill tag ── */
    .skill-tag {
        display: inline-flex;
        align-items: center;
        background: rgba(124,58,237,0.12);
        border: 1px solid rgba(124,58,237,0.25);
        color: #c4b5fd;
        font-size: 11px;
        font-weight: 700;
        padding: 3px 11px;
        border-radius: 9999px;
        white-space: nowrap;
        letter-spacing: 0.1px;
    }

    /* ── Badges ── */
    .badge-active {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: var(--success-bg);
        border: 1px solid rgba(34,197,94,0.25);
        color: var(--success);
        font-size: 10.5px;
        font-weight: 800;
        padding: 4px 10px;
        border-radius: 9999px;
        letter-spacing: 0.4px;
        text-transform: uppercase;
    }
    .badge-inactive {
        display: inline-flex;
        align-items: center;
        background: rgba(82,82,91,0.15);
        border: 1px solid rgba(82,82,91,0.25);
        color: var(--text-muted);
        font-size: 10.5px;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 9999px;
        letter-spacing: 0.4px;
        text-transform: uppercase;
    }

    /* ── History table ── */
    .rp-table {
        --bs-table-bg: transparent;
        --bs-table-border-color: var(--border);
        font-size: 13px;
        margin-bottom: 0;
    }
    .rp-table thead th {
        font-size: 10px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        color: var(--text-muted);
        padding: 10px 14px;
        border-bottom: 1px solid var(--border);
        background: var(--bg-elevated);
    }
    .rp-table tbody tr {
        border-bottom: 1px solid var(--border);
        transition: background 0.15s ease;
    }
    .rp-table tbody tr:last-child { border-bottom: none; }
    .rp-table tbody tr:hover { background: rgba(124,58,237,0.05); }
    .rp-table tbody td {
        padding: 13px 14px;
        vertical-align: middle;
        color: var(--text-secondary);
    }

    /* ── Table action buttons ── */
    .tbl-btn {
        padding: 5px 11px;
        font-size: 11.5px;
        font-weight: 700;
        border-radius: var(--r-sm);
        transition: all 0.18s ease;
        line-height: 1.25;
    }
    .tbl-btn-set {
        background: rgba(124,58,237,0.12);
        border: 1px solid rgba(124,58,237,0.30);
        color: #c4b5fd;
    }
    .tbl-btn-set:hover {
        background: rgba(124,58,237,0.22);
        border-color: var(--border-hover);
        color: #ddd6fe;
        box-shadow: var(--glow-sm);
    }
    .tbl-btn-view {
        background: var(--info-bg);
        border: 1px solid rgba(59,130,246,0.25);
        color: var(--info);
    }
    .tbl-btn-view:hover {
        background: rgba(59,130,246,0.20);
        color: #93c5fd;
    }
    .tbl-btn-del {
        background: var(--danger-bg);
        border: 1px solid rgba(239,68,68,0.25);
        color: var(--danger);
    }
    .tbl-btn-del:hover {
        background: rgba(239,68,68,0.20);
        color: #fca5a5;
    }

    /* ── Empty state ── */
    .empty-state {
        text-align: center;
        padding: 44px 20px;
    }
    .empty-state-icon {
        width: 68px;
        height: 68px;
        border-radius: var(--r-xl);
        background: rgba(124,58,237,0.08);
        border: 1px solid rgba(124,58,237,0.15);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        color: var(--accent-violet);
        margin: 0 auto 18px;
        opacity: 0.75;
    }

    /* ── Profile avatar ── */
    .profile-avatar {
        width: 48px;
        height: 48px;
        border-radius: var(--r-md);
        background: var(--grad-hot);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        color: #fff;
        box-shadow: 0 0 18px rgba(236,72,153,0.30);
        flex-shrink: 0;
    }

    /* ── Saved profile strip ── */
    .saved-strip {
        background: rgba(99,102,241,0.06);
        border: 1px solid rgba(99,102,241,0.14);
        border-radius: var(--r-lg);
        padding: 16px;
    }
    .saved-strip-title {
        font-size: 10px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        margin-bottom: 12px;
        background: var(--grad-primary);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        display: flex;
        align-items: center;
        gap: 5px;
    }
    .saved-strip-row {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 12.5px;
        color: var(--text-secondary);
        margin-bottom: 8px;
    }
    .saved-strip-row:last-child { margin-bottom: 0; }
    .saved-strip-row i { color: var(--text-muted); font-size: 13px; flex-shrink: 0; }

    /* ── Divider ── */
    .rp-divider {
        border: none;
        border-top: 1px solid var(--border);
        margin: 22px 0;
    }

    /* ── File icon bubble ── */
    .file-bubble {
        width: 32px;
        height: 32px;
        border-radius: var(--r-sm);
        background: var(--danger-bg);
        border: 1px solid rgba(239,68,68,0.20);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        color: var(--danger);
        flex-shrink: 0;
    }

    /* ── Gradient number heading (stats) ── */
    .grad-text {
        background: var(--grad-primary);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        font-weight: 900;
    }
</style>

<div class="row g-4">

    <!-- ══════════════════════════════════════════════════════════════ -->
    <!-- LEFT COLUMN — Resume Management                                -->
    <!-- ══════════════════════════════════════════════════════════════ -->
    <div class="col-xl-7 col-lg-6">

        <!-- ── Active Resume ── -->
        @if (Model != null)
        {
            <div class="rp-card mb-4">
                <div class="rp-header">
                    <div class="rp-header-icon icon-hot">
                        <i class="bi bi-file-earmark-check-fill"></i>
                    </div>
                    <div class="flex-grow-1">
                        <p class="rp-header-title">Active Resume</p>
                        <p class="rp-header-sub">Currently selected for job matching</p>
                    </div>
                    <span class="badge-active">
                        <i class="bi bi-circle-fill" style="font-size:5px;"></i>Default
                    </span>
                </div>

                <div class="active-preview">
                    <!-- File row -->
                    @if (!string.IsNullOrWhiteSpace(Model.FilePath))
                    {
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="file-bubble">
                                <i class="bi bi-file-earmark-pdf-fill"></i>
                            </div>
                            <div class="flex-grow-1">
                                <p class="active-preview-title mb-0">@System.IO.Path.GetFileName(Model.FilePath)</p>
                                <p class="active-preview-sub">PDF Resume</p>
                            </div>
                            <a href="@Url.Action("ViewFile", "Resume", new { id = Model.Id })" target="_blank"
                               class="tbl-btn tbl-btn-view text-decoration-none">
                                <i class="bi bi-box-arrow-up-right me-1"></i>View
                            </a>
                        </div>
                    }

                    <!-- Skills -->
                    @if (activeSkills.Count > 0)
                    {
                        <div class="mb-3">
                            <span class="field-label">Skills</span>
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var skill in activeSkills)
                                {
                                    <span class="skill-tag">@skill.Trim()</span>
                                }
                            </div>
                        </div>
                    }

                    <!-- Experience + Education -->
                    @if (!string.IsNullOrWhiteSpace(Model.Experience) || !string.IsNullOrWhiteSpace(Model.Education))
                    {
                        <div class="row g-3 mt-0">
                            @if (!string.IsNullOrWhiteSpace(Model.Experience))
                            {
                                <div class="col-md-6">
                                    <span class="field-label">Experience</span>
                                    <p style="font-size:12.5px; color:var(--text-secondary); line-height:1.6; margin:0;">@Model.Experience</p>
                                </div>
                            }
                            @if (!string.IsNullOrWhiteSpace(Model.Education))
                            {
                                <div class="col-md-6">
                                    <span class="field-label">Education</span>
                                    <p style="font-size:12.5px; color:var(--text-secondary); line-height:1.6; margin:0;">@Model.Education</p>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }

        <!-- ── Upload New Resume ── -->
        <div class="rp-card mb-4">
            <div class="rp-header">
                <div class="rp-header-icon">
                    <i class="bi bi-cloud-arrow-up-fill"></i>
                </div>
                <div>
                    <p class="rp-header-title">Upload New Resume</p>
                    <p class="rp-header-sub">Add a PDF and let AI extract your details automatically</p>
                </div>
            </div>

            <form method="post" asp-action="Upload" enctype="multipart/form-data" id="uploadForm">
                <div class="row g-3">

                    <!-- File picker -->
                    <div class="col-12">
                        <label class="field-label">Resume PDF</label>
                        <div class="file-drop-zone" id="fileDropZone">
                            <input type="file" id="resumeFileInput" name="resumeFile" accept=".pdf" required />
                            <i class="bi bi-file-earmark-arrow-up drop-icon"></i>
                            <div class="drop-label">Drop your PDF here or click to browse</div>
                            <div class="drop-sub">Only PDF files are accepted — max 10 MB</div>
                        </div>
                        <div id="fileNameDisplay"></div>

                        <div class="d-flex align-items-center gap-3 mt-3">
                            <button type="button" class="btn-parse" id="autoParseBtn">
                                <i class="bi bi-stars"></i>Auto-Parse with AI
                            </button>
                            <span class="field-hint" style="margin:0;">Extracts skills, experience &amp; education from the PDF.</span>
                        </div>
                    </div>

                    <!-- Full text -->
                    <div class="col-12">
                        <label class="field-label" for="fullTextInput">Resume Full Text</label>
                        <div class="input-icon-group ta-group">
                            <i class="bi bi-text-left ii"></i>
                            <textarea id="fullTextInput" name="fullText" class="form-control" rows="6"
                                      placeholder="Paste your full resume text here, or use Auto-Parse above to fill it automatically..." required></textarea>
                        </div>
                        <div class="field-hint">Used for AI-powered job match scoring.</div>
                    </div>

                    <!-- Skills -->
                    <div class="col-12">
                        <label class="field-label" for="skillsInput">
                            Skills
                            <span style="font-weight:400; text-transform:none; letter-spacing:0; color:var(--text-muted); font-size:11px; margin-left:4px;">comma-separated</span>
                        </label>
                        <div class="input-icon-group">
                            <i class="bi bi-tags ii"></i>
                            <input id="skillsInput" type="text" name="skills" class="form-control"
                                   placeholder="e.g. C#, .NET Core, React, SQL Server, Docker, Azure..." />
                        </div>
                        <div class="field-hint">Separate each skill with a comma. Auto-Parse will fill this in for you.</div>
                    </div>

                    <!-- Experience + Education -->
                    <div class="col-md-6">
                        <label class="field-label" for="experienceInput">Work Experience</label>
                        <div class="input-icon-group ta-group">
                            <i class="bi bi-briefcase ii"></i>
                            <textarea id="experienceInput" name="experience" class="form-control" rows="4"
                                      placeholder="e.g. 3 years as a Software Engineer at Acme Corp, building REST APIs..."></textarea>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <label class="field-label" for="educationInput">Education</label>
                        <div class="input-icon-group ta-group">
                            <i class="bi bi-mortarboard ii"></i>
                            <textarea id="educationInput" name="education" class="form-control" rows="4"
                                      placeholder="e.g. B.Tech in Computer Science, JNTU Hyderabad, 2022..."></textarea>
                        </div>
                    </div>

                    <!-- Submit -->
                    <div class="col-12 pt-1">
                        <button type="submit" class="btn-primary-action">
                            <i class="bi bi-plus-circle-fill"></i>Upload &amp; Activate Resume
                        </button>
                    </div>

                </div>
            </form>
        </div>

        <!-- ── Resume History ── -->
        <div class="rp-card">
            <div class="rp-header">
                <div class="rp-header-icon icon-teal">
                    <i class="bi bi-clock-history"></i>
                </div>
                <div class="flex-grow-1">
                    <p class="rp-header-title">Resume History</p>
                    <p class="rp-header-sub">
                        <span class="grad-text">@allResumes.Count</span>
                        resume@(allResumes.Count == 1 ? "" : "s") uploaded
                    </p>
                </div>
            </div>

            @if (allResumes.Count == 0)
            {
                <div class="empty-state">
                    <div class="empty-state-icon">
                        <i class="bi bi-file-earmark-pdf"></i>
                    </div>
                    <p style="font-weight:700; color:var(--text-primary); margin-bottom:6px;">No resumes uploaded yet</p>
                    <p style="font-size:12.5px; color:var(--text-muted); max-width:260px; margin:0 auto; line-height:1.6;">
                        Use the upload panel above to add your first resume and let AutoMail start matching jobs.
                    </p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-dark rp-table align-middle">
                        <thead>
                            <tr>
                                <th>File</th>
                                <th>Uploaded</th>
                                <th class="text-center">Status</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var resume in allResumes)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="file-bubble">
                                                <i class="bi bi-file-earmark-pdf-fill"></i>
                                            </div>
                                            <div>
                                                <span style="font-weight:700; color:var(--text-primary); font-size:12.5px; display:block;">
                                                    @(string.IsNullOrEmpty(resume.FilePath) ? "Text-Only Profile" : System.IO.Path.GetFileName(resume.FilePath))
                                                </span>
                                                @if (!string.IsNullOrWhiteSpace(resume.Experience))
                                                {
                                                    <span style="font-size:11px; color:var(--text-muted); display:block; max-width:200px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                                                        @(resume.Experience.Length > 50 ? resume.Experience.Substring(0, 50) + "…" : resume.Experience)
                                                    </span>
                                                }
                                            </div>
                                        </div>
                                    </td>
                                    <td style="font-size:12px; white-space:nowrap; color:var(--text-muted);">
                                        @resume.UploadedAt.ToIst().ToString("MMM dd, yyyy HH:mm")
                                    </td>
                                    <td class="text-center">
                                        @if (resume.IsActive)
                                        {
                                            <span class="badge-active">
                                                <i class="bi bi-circle-fill" style="font-size:5px;"></i>Active
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge-inactive">Inactive</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <div class="d-inline-flex align-items-center gap-1">
                                            @if (!resume.IsActive)
                                            {
                                                <form method="post" asp-action="SetDefault" asp-route-id="@resume.Id" class="d-inline">
                                                    <button type="submit" class="tbl-btn tbl-btn-set" title="Set as default">
                                                        <i class="bi bi-check2-circle me-1"></i>Set Default
                                                    </button>
                                                </form>
                                            }
                                            @if (!string.IsNullOrEmpty(resume.FilePath))
                                            {
                                                <a href="@Url.Action("ViewFile", "Resume", new { id = resume.Id })" target="_blank"
                                                   class="tbl-btn tbl-btn-view text-decoration-none" title="View PDF">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                            }
                                            <form method="post" asp-action="Delete" asp-route-id="@resume.Id" class="d-inline"
                                                  onsubmit="return confirm('Delete this resume permanently?');">
                                                <button type="submit" class="tbl-btn tbl-btn-del" title="Delete">
                                                    <i class="bi bi-trash3"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

    </div>

    <!-- ══════════════════════════════════════════════════════════════ -->
    <!-- RIGHT COLUMN — User Profile                                    -->
    <!-- ══════════════════════════════════════════════════════════════ -->
    <div class="col-xl-5 col-lg-6">

        <div class="rp-card" style="position: sticky; top: 24px;">

            <!-- Profile header -->
            <div class="rp-header">
                <div class="profile-avatar">
                    <i class="bi bi-person-fill"></i>
                </div>
                <div>
                    <p class="rp-header-title">Personal Profile</p>
                    <p class="rp-header-sub">Contact details used in outreach emails</p>
                </div>
            </div>

            <form method="post" asp-action="UpdateProfile">
                <div class="row g-3">

                    <!-- Full Name -->
                    <div class="col-12">
                        <label class="field-label" for="fullNameInput">Full Name</label>
                        <div class="input-icon-group">
                            <i class="bi bi-person ii"></i>
                            <input id="fullNameInput" type="text" name="fullName" class="form-control"
                                   value="@(profile?.FullName)"
                                   placeholder="e.g. Chaitanya Mallelli"
                                   required />
                        </div>
                    </div>

                    <!-- Email -->
                    <div class="col-12">
                        <label class="field-label" for="emailInput">Email Address</label>
                        <div class="input-icon-group">
                            <i class="bi bi-envelope ii"></i>
                            <input id="emailInput" type="email" name="email" class="form-control"
                                   value="@(profile?.Email)"
                                   placeholder="e.g. you@example.com"
                                   required />
                        </div>
                        <div class="field-hint">Used as the sender address in Gmail outreach emails.</div>
                    </div>

                    <!-- Phone -->
                    <div class="col-12">
                        <label class="field-label" for="phoneInput">Phone Number</label>
                        <div class="input-icon-group">
                            <i class="bi bi-telephone ii"></i>
                            <input id="phoneInput" type="text" name="phone" class="form-control"
                                   value="@(profile?.Phone)"
                                   placeholder="e.g. +91 98765 43210" />
                        </div>
                    </div>

                    <!-- LinkedIn -->
                    <div class="col-12">
                        <label class="field-label" for="linkedInInput">LinkedIn Profile URL</label>
                        <div class="input-icon-group">
                            <i class="bi bi-linkedin ii"></i>
                            <input id="linkedInInput" type="url" name="linkedInUrl" class="form-control"
                                   value="@(profile?.LinkedInUrl)"
                                   placeholder="https://linkedin.com/in/your-handle" />
                        </div>
                        <div class="field-hint">Included in application emails so recruiters can view your profile.</div>
                    </div>

                    <hr class="rp-divider" style="margin: 4px 0 0;" />

                    <!-- Save -->
                    <div class="col-12">
                        <button type="submit" class="btn-primary-action">
                            <i class="bi bi-check-circle-fill"></i>Save Profile
                        </button>
                    </div>

                </div>
            </form>

            <!-- Saved profile strip -->
            @if (profile != null && (!string.IsNullOrWhiteSpace(profile.FullName) || !string.IsNullOrWhiteSpace(profile.Email)))
            {
                <hr class="rp-divider" />
                <div class="saved-strip">
                    <div class="saved-strip-title">
                        <i class="bi bi-shield-check" style="-webkit-text-fill-color:unset; background:none; color:#818cf8;"></i>
                        Saved Profile
                    </div>
                    @if (!string.IsNullOrWhiteSpace(profile.FullName))
                    {
                        <div class="saved-strip-row">
                            <i class="bi bi-person-fill"></i>
                            <span>@profile.FullName</span>
                        </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(profile.Email))
                    {
                        <div class="saved-strip-row">
                            <i class="bi bi-envelope-fill"></i>
                            <span>@profile.Email</span>
                        </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(profile.Phone))
                    {
                        <div class="saved-strip-row">
                            <i class="bi bi-telephone-fill"></i>
                            <span>@profile.Phone</span>
                        </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(profile.LinkedInUrl))
                    {
                        <div class="saved-strip-row">
                            <i class="bi bi-linkedin"></i>
                            <a href="@profile.LinkedInUrl" target="_blank"
                               style="color:var(--accent-indigo); text-decoration:none; font-weight:600;">
                                View LinkedIn
                            </a>
                        </div>
                    }
                </div>
            }

        </div>
    </div>

</div>

@section Scripts {
    <script>
        // ── File picker: show filename and update drop zone ────────────────
        const fileInput   = document.getElementById('resumeFileInput');
        const dropZone    = document.getElementById('fileDropZone');
        const fileDisplay = document.getElementById('fileNameDisplay');

        fileInput.addEventListener('change', function () {
            const file = this.files[0];
            if (file) {
                fileDisplay.innerHTML = '<i class="bi bi-file-earmark-pdf-fill" style="color:#ef4444;margin-right:5px;"></i>' + file.name;
                dropZone.style.borderColor = 'rgba(124,58,237,0.60)';
                dropZone.style.background  = 'rgba(124,58,237,0.10)';
                dropZone.style.boxShadow   = '0 0 12px rgba(124,58,237,0.20)';
            } else {
                fileDisplay.textContent    = '';
                dropZone.style.borderColor = '';
                dropZone.style.background  = '';
                dropZone.style.boxShadow   = '';
            }
        });

        // Drag-over visual feedback
        dropZone.addEventListener('dragover', function (e) {
            e.preventDefault();
            this.classList.add('dragover');
        });
        dropZone.addEventListener('dragleave', function () {
            this.classList.remove('dragover');
        });
        dropZone.addEventListener('drop', function () {
            this.classList.remove('dragover');
        });

        // ── Auto-parse button ─────────────────────────────────────────────
        document.getElementById('autoParseBtn').addEventListener('click', async function () {
            const file = fileInput.files[0];

            if (!file) {
                showToast('Please select a PDF file first.', 'warning');
                return;
            }
            if (file.type !== 'application/pdf') {
                showToast('Only PDF files are supported for auto-parsing.', 'warning');
                return;
            }

            const btn = this;
            const originalHTML = btn.innerHTML;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm" style="width:12px;height:12px;border-width:2px;"></span>&nbsp;Parsing with AI...';
            btn.disabled = true;

            const formData = new FormData();
            formData.append('resumeFile', file);

            try {
                const response = await fetch('@Url.Action("AutoParse", "Resume")', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();

                if (result.success) {
                    document.getElementById('fullTextInput').value   = result.fullText   || '';
                    document.getElementById('skillsInput').value     = result.skills     || '';
                    document.getElementById('experienceInput').value = result.experience || '';
                    document.getElementById('educationInput').value  = result.education  || '';
                    showToast('Resume parsed successfully. Review the fields before uploading.', 'success');
                } else {
                    showToast('Parse failed: ' + (result.message || 'Unknown error'), 'danger');
                }
            } catch (err) {
                console.error(err);
                showToast('A network error occurred during parsing.', 'danger');
            } finally {
                btn.innerHTML = originalHTML;
                btn.disabled  = false;
            }
        });

        // ── Toast helper ─────────────────────────────────────────────────
        function showToast(message, type) {
            const palette = {
                success: { bg: 'rgba(34,197,94,0.10)',  border: 'rgba(34,197,94,0.28)',  color: '#4ade80' },
                warning: { bg: 'rgba(245,158,11,0.10)', border: 'rgba(245,158,11,0.28)', color: '#fbbf24' },
                danger:  { bg: 'rgba(239,68,68,0.10)',  border: 'rgba(239,68,68,0.28)',  color: '#f87171' }
            };
            const c = palette[type] || palette.success;

            const el = document.createElement('div');
            el.style.cssText = [
                'position:fixed', 'top:20px', 'right:24px', 'z-index:9999',
                'padding:13px 18px', 'border-radius:12px', 'font-size:13px', 'font-weight:600',
                'max-width:340px', 'line-height:1.5',
                'box-shadow:0 8px 40px rgba(0,0,0,0.45)',
                'transition:opacity 0.3s ease', 'opacity:0',
                'background:' + c.bg,
                'border:1px solid ' + c.border,
                'color:' + c.color,
                'font-family:Inter,-apple-system,sans-serif'
            ].join(';');
            el.textContent = message;

            document.body.appendChild(el);
            requestAnimationFrame(() => { el.style.opacity = '1'; });
            setTimeout(() => {
                el.style.opacity = '0';
                setTimeout(() => el.remove(), 320);
            }, 4000);
        }
    </script>
}
