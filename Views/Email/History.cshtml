@model List<JobAutomation.Models.GeneratedEmail>
@{
    ViewData["Title"] = "Email History";
    ViewData["Subtitle"] = "Track all generated and sent emails";
}

<style>
    /* ── History page local styles ──────────────────────────── */

    /* Filter bar enhancements */
    .history-filter-bar {
        background: var(--color-bg-card);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        padding: 14px 20px;
        margin-bottom: 24px;
        animation: fadeInUp 0.35s ease both;
    }

    .history-filter-form {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
    }

    .history-search-wrap {
        flex: 1;
        min-width: 220px;
        position: relative;
    }

    .history-search-wrap .search-icon {
        position: absolute;
        left: 13px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--color-text-muted);
        font-size: 14px;
        pointer-events: none;
        z-index: 1;
    }

    .history-search-wrap .form-control {
        padding-left: 38px !important;
    }

    .history-status-select {
        min-width: 148px;
    }

    .btn-export-csv {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 16px;
        border-radius: var(--radius-md);
        border: 1px solid var(--color-border-medium);
        background: transparent;
        color: var(--color-text-secondary);
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        white-space: nowrap;
        transition: all var(--transition-fast);
        line-height: 1.4;
    }

    .btn-export-csv:hover {
        background: rgba(148, 163, 184, 0.08);
        border-color: rgba(148, 163, 184, 0.28);
        color: var(--color-text-primary);
        text-decoration: none;
    }

    .btn-export-csv i {
        font-size: 14px;
        color: var(--color-accent-light);
        opacity: 0.85;
    }

    /* ── Table enhancements ────────────────────────────────── */
    .history-table-card {
        background: var(--color-bg-card);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        animation: fadeInUp 0.40s ease 0.05s both;
    }

    .history-table-scroll {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
    }

    .history-table {
        margin: 0;
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        color: var(--color-text-primary);
    }

    /* Sticky header */
    .history-table thead {
        position: sticky;
        top: 0;
        z-index: 10;
    }

    .history-table thead th {
        background: rgba(0, 0, 0, 0.26);
        border-bottom: 1px solid var(--color-border);
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1.2px;
        color: var(--color-text-muted);
        padding: 13px 16px;
        white-space: nowrap;
        vertical-align: middle;
        backdrop-filter: blur(6px);
        -webkit-backdrop-filter: blur(6px);
    }

    .history-table tbody tr {
        border-bottom: 1px solid var(--color-border-light);
        transition: background var(--transition-fast);
    }

    .history-table tbody tr:last-child {
        border-bottom: none;
    }

    /* Alternating subtle row tint */
    .history-table tbody tr:nth-child(even) {
        background: rgba(255, 255, 255, 0.012);
    }

    .history-table tbody tr:hover {
        background: var(--color-bg-card-hover);
    }

    .history-table tbody td {
        padding: 12px 16px;
        vertical-align: middle;
        border: none;
        font-size: 13.5px;
        color: var(--color-text-primary);
    }

    /* ── Company avatar variants ───────────────────────────── */
    .company-avatar.av-a, .company-avatar.av-b { background: linear-gradient(135deg, #6366f1, #8b5cf6); }
    .company-avatar.av-c, .company-avatar.av-d { background: linear-gradient(135deg, #22c55e, #10b981); }
    .company-avatar.av-e, .company-avatar.av-f { background: linear-gradient(135deg, #f59e0b, #f97316); }
    .company-avatar.av-g, .company-avatar.av-h { background: linear-gradient(135deg, #3b82f6, #6366f1); }
    .company-avatar.av-i, .company-avatar.av-j { background: linear-gradient(135deg, #ec4899, #8b5cf6); }
    .company-avatar.av-k, .company-avatar.av-l { background: linear-gradient(135deg, #14b8a6, #06b6d4); }
    .company-avatar.av-m, .company-avatar.av-n { background: linear-gradient(135deg, #a855f7, #6366f1); }
    .company-avatar.av-o, .company-avatar.av-p { background: linear-gradient(135deg, #f43f5e, #ec4899); }
    .company-avatar.av-q, .company-avatar.av-r { background: linear-gradient(135deg, #0ea5e9, #3b82f6); }
    .company-avatar.av-s, .company-avatar.av-t { background: linear-gradient(135deg, #84cc16, #22c55e); }
    .company-avatar.av-u, .company-avatar.av-v { background: linear-gradient(135deg, #f97316, #f59e0b); }
    .company-avatar.av-w, .company-avatar.av-x { background: linear-gradient(135deg, #8b5cf6, #a855f7); }
    .company-avatar.av-y, .company-avatar.av-z { background: linear-gradient(135deg, #06b6d4, #14b8a6); }
    .company-avatar.av-default               { background: linear-gradient(135deg, #6366f1, #8b5cf6); }

    /* ── Recipient email mono style ────────────────────────── */
    .recipient-email {
        font-family: 'JetBrains Mono', 'Fira Code', 'Courier New', monospace;
        font-size: 12px;
        color: var(--color-accent-light);
        max-width: 180px;
        display: inline-block;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        vertical-align: bottom;
        letter-spacing: -0.2px;
    }

    /* ── Subject truncation ─────────────────────────────────── */
    .subject-cell {
        font-size: 13px;
        color: var(--color-text-secondary);
        max-width: 240px;
        display: inline-block;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        vertical-align: bottom;
    }

    /* ── Opened badge ───────────────────────────────────────── */
    .opened-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 4px 9px;
        border-radius: var(--radius-full);
        font-size: 11px;
        font-weight: 600;
        background: rgba(34, 197, 94, 0.13);
        color: #4ade80;
        border: 1px solid rgba(34, 197, 94, 0.22);
        white-space: nowrap;
    }

    .not-opened-text {
        font-size: 12px;
        color: var(--color-text-muted);
        font-style: italic;
    }

    /* ── Reply classification badges ────────────────────────── */
    .reply-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 4px 9px;
        border-radius: var(--radius-full);
        font-size: 11px;
        font-weight: 600;
        white-space: nowrap;
    }

    .reply-interview {
        background: rgba(99, 102, 241, 0.18);
        color: #a5b4fc;
        border: 1px solid rgba(99, 102, 241, 0.28);
    }

    .reply-rejected {
        background: rgba(239, 68, 68, 0.13);
        color: #f87171;
        border: 1px solid rgba(239, 68, 68, 0.22);
    }

    .reply-interested {
        background: rgba(251, 191, 36, 0.13);
        color: #fbbf24;
        border: 1px solid rgba(251, 191, 36, 0.22);
    }

    .reply-generic {
        background: rgba(148, 163, 184, 0.12);
        color: #94a3b8;
        border: 1px solid rgba(148, 163, 184, 0.20);
    }

    /* ── Action icon buttons ────────────────────────────────── */
    .btn-icon-view {
        width: 32px;
        height: 32px;
        min-width: 32px;
        padding: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: var(--radius-md);
        background: var(--color-accent-bg);
        color: var(--color-accent-light);
        border: 1px solid rgba(99, 102, 241, 0.18);
        transition: all var(--transition-fast);
        cursor: pointer;
        font-size: 14px;
        text-decoration: none;
        line-height: 1;
    }

    .btn-icon-view:hover {
        background: var(--color-accent);
        color: #fff;
        border-color: var(--color-accent);
        box-shadow: var(--shadow-glow-sm);
        transform: translateY(-1px);
        text-decoration: none;
    }

    .btn-icon-retry {
        width: 32px;
        height: 32px;
        min-width: 32px;
        padding: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: var(--radius-md);
        background: rgba(245, 158, 11, 0.12);
        color: #fbbf24;
        border: 1px solid rgba(245, 158, 11, 0.22);
        transition: all var(--transition-fast);
        cursor: pointer;
        font-size: 14px;
        line-height: 1;
        margin-left: 6px;
    }

    .btn-icon-retry:hover {
        background: var(--color-warning);
        color: #0a0f1e;
        border-color: var(--color-warning);
        transform: translateY(-1px);
        box-shadow: 0 0 12px rgba(245, 158, 11, 0.30);
    }

    .actions-cell {
        display: flex;
        align-items: center;
        white-space: nowrap;
    }

    /* ── Sent date ──────────────────────────────────────────── */
    .sent-date-text {
        font-size: 12.5px;
        color: var(--color-text-secondary);
        font-variant-numeric: tabular-nums;
        white-space: nowrap;
    }

    /* ── Empty state ────────────────────────────────────────── */
    .history-empty {
        padding: 72px 24px;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }

    .history-empty-icon {
        font-size: 56px;
        margin-bottom: 20px;
        display: block;
        background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        opacity: 0.55;
        animation: pulseBounce 3s ease-in-out infinite;
    }

    .history-empty h3 {
        font-size: 18px;
        font-weight: 600;
        color: var(--color-text-primary);
        margin-bottom: 8px;
        letter-spacing: -0.3px;
    }

    .history-empty p {
        color: var(--color-text-secondary);
        font-size: 14px;
        max-width: 340px;
        line-height: 1.65;
        margin: 0 auto;
    }

    /* ── Role text in table ─────────────────────────────────── */
    .role-cell {
        font-size: 13px;
        color: var(--color-text-secondary);
        white-space: nowrap;
        max-width: 160px;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    /* ── Mobile stacking ────────────────────────────────────── */
    @@media (max-width: 991.98px) {
        .history-filter-form {
            flex-direction: column;
            align-items: stretch;
        }
        .history-search-wrap {
            min-width: 100%;
        }
        .history-status-select {
            width: 100%;
            min-width: 0;
        }
        .btn-export-csv {
            justify-content: center;
            width: 100%;
        }
    }
</style>

<!-- ── Filter Bar ─────────────────────────────────────────── -->
<div class="history-filter-bar">
    <form method="get" class="history-filter-form" id="filterForm">

        <div class="history-search-wrap">
            <i class="bi bi-search search-icon"></i>
            <input type="text"
                   name="search"
                   id="searchInput"
                   class="form-control"
                   placeholder="Search by company, role, email..."
                   value="@ViewBag.Search" />
        </div>

        <select name="status"
                class="form-select history-status-select"
                onchange="document.getElementById('filterForm').submit()">
            <option value="">All Statuses</option>
            <option value="sent"     selected="@(ViewBag.Status == "sent"     ? "selected" : null)">Sent</option>
            <option value="approved" selected="@(ViewBag.Status == "approved" ? "selected" : null)">Approved</option>
            <option value="pending"  selected="@(ViewBag.Status == "pending"  ? "selected" : null)">Draft</option>
            <option value="failed"   selected="@(ViewBag.Status == "failed"   ? "selected" : null)">Failed</option>
        </select>

        <a href="@Url.Action("Export")" class="btn-export-csv">
            <i class="bi bi-download"></i>
            Export CSV
        </a>

    </form>
</div>

<!-- ── Table Card ────────────────────────────────────────────── -->
<div class="history-table-card">

    @if (Model.Count == 0)
    {
        <div class="history-empty">
            <span class="history-empty-icon">
                <i class="bi bi-robot"></i>
            </span>
            <h3>No emails found</h3>
            <p>No emails match your current filters. Process a job post to generate your first application email.</p>
        </div>
    }
    else
    {
        <div class="history-table-scroll">
            <table class="history-table">
                <thead>
                    <tr>
                        <th>Company</th>
                        <th>Role</th>
                        <th>Recipient</th>
                        <th>Subject</th>
                        <th>Status</th>
                        <th>Opened</th>
                        <th>Reply</th>
                        <th>Sent Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var email in Model)
                    {
                        var firstLetter = (email.JobPost?.CompanyName?.Length > 0
                            ? email.JobPost.CompanyName[0]
                            : '?');
                        var avatarClass = char.IsLetter(firstLetter)
                            ? "av-" + char.ToLower(firstLetter).ToString()
                            : "av-default";
                        <tr>

                            <!-- Company -->
                            <td>
                                <div class="company-cell">
                                    <div class="company-avatar @avatarClass">
                                        @firstLetter
                                    </div>
                                    <span class="company-name">
                                        @(email.JobPost?.CompanyName ?? "N/A")
                                    </span>
                                </div>
                            </td>

                            <!-- Role -->
                            <td>
                                <span class="role-cell" title="@(email.JobPost?.Role ?? "")">
                                    @(email.JobPost?.Role ?? "N/A")
                                </span>
                            </td>

                            <!-- Recipient -->
                            <td>
                                <span class="recipient-email" title="@email.RecipientEmail">
                                    @email.RecipientEmail
                                </span>
                            </td>

                            <!-- Subject -->
                            <td>
                                <span class="subject-cell" title="@email.Subject">
                                    @(email.Subject.Length > 45 ? email.Subject[..45] + "…" : email.Subject)
                                </span>
                            </td>

                            <!-- Status -->
                            <td>
                                @if (email.IsSent)
                                {
                                    <span class="status-badge status-sent">
                                        <i class="bi bi-check-circle-fill"></i> Sent
                                    </span>
                                }
                                else if (email.ErrorMessage != null)
                                {
                                    <span class="status-badge status-failed">
                                        <i class="bi bi-x-circle-fill"></i> Failed
                                    </span>
                                }
                                else if (email.IsApproved)
                                {
                                    <span class="status-badge status-approved">
                                        <i class="bi bi-check2-circle"></i> Approved
                                    </span>
                                }
                                else
                                {
                                    <span class="status-badge status-pending">
                                        <i class="bi bi-hourglass-split"></i> Draft
                                    </span>
                                }
                            </td>

                            <!-- Opened -->
                            <td>
                                @if (email.OpenedAt.HasValue)
                                {
                                    <span class="opened-badge" title="@email.OpenedAt?.ToString("f")">
                                        <i class="bi bi-eye-fill"></i>
                                        @email.OpenedAt.ToIstString("MMM dd")
                                    </span>
                                }
                                else if (email.IsSent)
                                {
                                    <span class="not-opened-text">Not opened</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>

                            <!-- Reply -->
                            <td>
                                @if (email.RepliedAt.HasValue)
                                {
                                    var (replyCls, replyIcon, replyLabel) = email.ReplyClassification switch {
                                        "interview"  => ("reply-interview",  "bi-telephone-fill",    "Interview"),
                                        "rejected"   => ("reply-rejected",   "bi-x-circle-fill",     "Rejected"),
                                        "interested" => ("reply-interested", "bi-star-fill",         "Interested"),
                                        _            => ("reply-generic",    "bi-envelope-open-fill","Replied")
                                    };
                                    <span class="reply-badge @replyCls" title="@email.RepliedAt?.ToString("f")">
                                        <i class="bi @replyIcon"></i>
                                        @replyLabel
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>

                            <!-- Sent Date -->
                            <td>
                                @if (email.SentAt.HasValue)
                                {
                                    <span class="sent-date-text"
                                          title="@email.SentAt.ToIstString("f", true)">
                                        @email.SentAt.ToIstString("MMM dd, HH:mm")
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>

                            <!-- Actions -->
                            <td>
                                <div class="actions-cell">
                                    <a href="@Url.Action("Preview", new { id = email.JobPostId })"
                                       class="btn-icon-view"
                                       title="View email">
                                        <i class="bi bi-eye"></i>
                                    </a>

                                    @if (!email.IsSent && email.ErrorMessage != null)
                                    {
                                        <form method="post"
                                              asp-action="Retry"
                                              asp-route-id="@email.JobPostId"
                                              class="d-inline"
                                              style="margin:0;">
                                            <button type="submit"
                                                    class="btn-icon-retry"
                                                    title="Retry sending">
                                                <i class="bi bi-arrow-clockwise"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>

                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

</div>
