## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Original source: https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/ActiveState ActiveGo)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Cc]lean/
x64/
x86/
SDK/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017 cache/options directory
.vs/
# Uncomment if multiple versions of Visual Studio are installed
# .vs*/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-agent-concourse.log

# Developer Activity Trends
_ReSharper*/
*.[Re]Sharper.user
*.DotSettings.user

# Visual Studio Image Depictor cache
Imagecache/

# Team City
_TeamCity*

# JetBrains Rider
.idea/
*.sln.iml

# Visual Studio Code
.vscode/

# Local configuration files
appsettings.local.json

# User Uploads and DB files
wwwroot/uploads/*
!wwwroot/uploads/.gitkeep
wwwroot/resumes/*
!wwwroot/resumes/.gitkeep

# Temporary and log files
*.log
*.tmp
