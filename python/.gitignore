# ── Secrets / local config (DB password, API keys, bot tokens) ──
# Real config is ignored; commit appsettings.example.json instead.
appsettings.json
appsettings.local.json
.env
*.local.json

# ── Virtual environments ──
.venv/
venv/
env/
ENV/

# ── Python bytecode / caches ──
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyrefly/

# ── Runtime artifacts ──
*.log
boot_*.log
scrape-debug/
Data/Sessions/
wwwroot/uploads/*
!wwwroot/uploads/.gitkeep

# ── Uploaded résumé files (keep the folder, drop the PDFs) ──
Resume/*
!Resume/.gitkeep

# ── SQLite fallback DB (used only if no Postgres connection string) ──
*.db
*.sqlite3

# ── OS / editor cruft ──
.vscode/
.idea/
.DS_Store
Thumbs.db
